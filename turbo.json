{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "deps": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "deps"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "build/**", "gomod2nix.toml"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.test.{ts,tsx}",
        "src/**/*.spec.{ts,tsx}"
      ],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "dependsOn": ["^deploy"],
      "cache": false
    },
    "web#destroy": {
      "cache": false
    }
  },
  "envMode": "loose"
}
