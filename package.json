{
  "name": "stackpanel",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "hono": "^4.8.2",
      "zod": "^4.1.13",
      "@trpc/server": "^11.5.0",
      "better-auth": "^1.4.5",
      "ai": "^5.0.49",
      "@ai-sdk/google": "^2.0.13",
      "dotenv": "^17.2.2",
      "alchemy": "^0.77.0",
      "@trpc/client": "^11.5.0",
      "@prisma/client": "^7.0.1",
      "@polar-sh/better-auth": "^1.1.3",
      "react": "^19.2.3",
      "react-dom": "^19.2.3"
    }
  },
  "scripts": {
    "check": "oxlint --fix .",
    "lint": "oxlint .",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "dev": "alchemy dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @stackpanel/db db:push",
    "db:studio": "turbo -F @stackpanel/db db:studio",
    "db:generate": "turbo -F @stackpanel/db db:generate",
    "db:migrate": "turbo -F @stackpanel/db db:migrate",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy"
  },
  "dependencies": {
    "@intellectronica/ruler": "^0.3.18",
    "dotenv": "^17.2.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.953.0",
    "@aws-sdk/client-ssm": "^3.953.0",
    "oxlint": "^1.2.0",
    "@cloudflare/workers-types": "^4.20250822.0",
    "@types/node": "^22.13.11",
    "alchemy": "^0.77.0",
    "turbo": "^2.5.4",
    "ultracite": "6.3.9"
  },
  "packageManager": "bun@1.3.2"
}
