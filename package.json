{
  "name": "stackpanel",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/ui/*",
      "packages/gen/*"
    ],
    "catalog": {
      "hono": "^4.8.2",
      "zod": "^4.1.13",
      "better-auth": "^1.4.5",
      "ai": "^5.0.49",
      "@ai-sdk/google": "^2.0.13",
      "dotenv": "^17.2.2",
      "alchemy": "^0.77.0",
      "alchemy-effect": "^0.12.0",
      "@aws-sdk/credential-providers": "^3.0.0",
      "@cloudflare/containers": "^0.1.1",
      "@cloudflare/vite-plugin": "^1.13.12",
      "@cloudflare/workers-types": "^4.20250805.0",
      "@distilled.cloud/aws": "^0.10.0",
      "@distilled.cloud/cloudflare-bundler": "0.2.1",
      "@distilled.cloud/cloudflare": "^0.10.0",
      "@distilled.cloud/core": "^0.10.0",
      "@distilled.cloud/fly-io": "^0.11.0",
      "@effect/language-service": "^0.85.1",
      "@effect/platform-node-shared": "4.0.0-beta.48",
      "@effect/platform-node": "4.0.0-beta.48",
      "@effect/platform-bun": "4.0.0-beta.48",
      "@effect/vitest": "4.0.0-beta.48",
      "@tanstack/react-query": "^5.90.12",
      "@tanstack/react-router": "^1.143.6",
      "@trpc/server": "^11.7.2",
      "@trpc/client": "^11.7.2",
      "@trpc/tanstack-react-query": "^11.7.2",
      "@prisma/client": "^7.0.1",
      "@polar-sh/better-auth": "^1.1.3",
      "effect": "4.0.0-beta.48",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "tailwindcss": "^4.1.16",
      "sst": "^3.17.25",
      "@pulumi/aws": "^7.15.0",
      "@aws-sdk/client-ec2": "^3.953.0",
      "@aws-sdk/client-ecr": "^3.953.0",
      "@aws-sdk/client-elastic-load-balancing-v2": "^3.953.0",
      "@aws-sdk/client-iam": "^3.953.0",
      "@aws-sdk/client-kms": "^3.953.0",
      "@aws-sdk/client-sts": "^3.953.0",
      "@aws-sdk/client-ssm": "^3.953.0",
      "@typescript/native-preview": "latest"
    }
  },
  "scripts": {
    "check": "vp lint && vp fmt --write",
    "lint": "vp lint .",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "test": "turbo test",
    "db:push": "turbo -F @stackpanel/db db:push",
    "db:studio": "turbo -F @stackpanel/db db:studio",
    "db:generate": "turbo -F @stackpanel/db db:generate",
    "db:migrate": "turbo -F @stackpanel/db db:migrate",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@intellectronica/ruler": "^0.3.18",
    "@pulumi/aws": "^7.15.0",
    "@pulumi/command": "^1.1.3",
    "db": "^6.0.3",
    "dotenv": "^17.2.2",
    "effect": "^3.21.0",
    "infra": "^1.0.3",
    "sst": "^3.17.25",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.953.0",
    "@aws-sdk/client-ssm": "^3.953.0",
    "@cloudflare/workers-types": "^4.20250822.0",
    "@distilled.cloud/cloudflare-rolldown-plugin": "0.2.0",
    "@distilled.cloud/cloudflare-vite-plugin": "0.1.0",
    "@effect/language-service": "^0.77.0",
    "@gen/config": "workspace:*",
    "@gen/env": "workspace:*",
    "@mdx-js/rollup": "^3.1.1",
    "@pulumi/pulumi": "^3.213.0",
    "@types/node": "^22.13.11",
    "@typescript/native-preview": "^7.0.0-dev.20260317.1",
    "alchemy": "^0.77.0",
    "bun2nix": "^2.0.6",
    "cloudflare": "^5.2.0",
    "rolldown": "1.0.0-rc.13",
    "turbo": "^2.5.4",
    "typescript": "latest",
    "ultracite": "6.3.9",
    "vite": "^8.0.7",
    "workerd": "1.20260412.1"
  },
  "packageManager": "bun@1.3.2",
  "overrides": {
    "effect": "4.0.0-beta.48",
    "@effect/platform-node": "4.0.0-beta.48",
    "@effect/platform-node-shared": "4.0.0-beta.48",
    "@effect/platform-bun": "4.0.0-beta.48"
  }
}
