{
	"include": ["**/*.ts", "**/*.tsx", "*.ts"],
	"compilerOptions": {
		"target": "ES2022",
		"jsx": "react-jsx",
		"module": "ESNext",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["vite/client"],

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,

		/* Linting */
		"skipLibCheck": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true,
		"paths": {
			"@/*": ["./src/*"],
			"@ui": ["./src/components/ui"],
			"@ui/*": ["./src/components/ui/*"],
			"@gen/featureflags": ["../../packages/gen/featureflags/src/index.ts"],
			"@gen/featureflags/*": ["../../packages/gen/featureflags/src/*"],
		}
	}
}
