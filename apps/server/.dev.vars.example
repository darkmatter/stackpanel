# Copy this file to .dev.vars and fill in the values
# Wrangler uses .dev.vars for local development secrets

# Database (Neon PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:6401

# Polar payments
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=http://localhost:6402/success

# CORS
CORS_ORIGIN=http://localhost:6402

# Google AI
GOOGLE_GENERATIVE_AI_API_KEY=
