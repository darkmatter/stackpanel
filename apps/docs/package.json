{
  "dependencies": {
    "@fontsource-variable/google-sans-code": "^5.2.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource-variable/source-code-pro": "^5.2.7",
    "@fontsource/monaspace-neon": "^5.2.5",
    "@opennextjs/cloudflare": "^1.17.1",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-presence": "^1.1.5",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@stackpanel/sdk": "workspace:*",
    "@stackpanel/ui-core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "fumadocs-core": "16.2.3",
    "fumadocs-mdx": "14.1.0",
    "fumadocs-typescript": "5.0.0",
    "fumadocs-ui": "16.2.3",
    "lucide-react": "^0.552.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "scroll-into-view-if-needed": "^3.1.0",
    "shiki": "3.19.0",
    "tailwind-merge": "^3.4.0",
    "ts-morph": "^27.0.2",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@distilled.cloud/cloudflare": "^0.7.11",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "alchemy": "catalog:",
    "alchemy-effect": "catalog:",
    "mdast-util-mdx-jsx": "^3.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "catalog:",
    "typescript": "^5.9.3",
    "wrangler": "^4.81.0"
  },
  "name": "docs",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy": "bun run build:worker && bunx alchemy deploy",
    "deploy:dev": "APP_ENV=dev bun run build:worker && bunx alchemy deploy --stage dev",
    "deploy:opennext": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:production": "APP_ENV=prod STAGE=production bun run build:worker && bunx alchemy deploy --stage production",
    "deploy:staging": "APP_ENV=staging STAGE=staging bun run build:worker && bunx alchemy deploy --stage staging",
    "destroy": "bunx alchemy destroy",
    "dev": "next dev --port=${PORT:-4000}",
    "dev:portless": "portless docs.stackpanel --app-port 5738  bun run dev",
    "postinstall": "fumadocs-mdx",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload"
  },
  "version": "0.0.0"
}
