{
  "dependencies": {
    "@stackpanel/scripts": "workspace:*"
  },
  "name": "cli",
  "private": true,
  "scripts": {
    "build": "bun run deps && go build -ldflags \"-s -w\" -o ./build/cli .",
    "deps": "go mod tidy && gomod2nix generate --with-deps",
    "dev": "air",
    "format": "gofumpt -l -w .",
    "lint": "golangci-lint run ./...",
    "postinstall": "bun run deps",
    "preinstall": "check-devshell",
    "test": "go test -v ./..."
  }
}
