# Auto-generated by stackpanel secrets:init-group
# DO NOT EDIT — re-run secrets:init-group to regenerate.
#
# Re-encrypts group .enc.age files when the recipients list changes.
# Self-service team onboarding:
#   1. New member enters devshell (auto-generates AGE key)
#   2. They run `secrets:join` to add their key to recipients/team/
#   3. They commit + push the .age.pub file
#   4. This workflow re-encrypts .enc.age files for ALL recipients
#   5. They pull and can now decrypt secrets

name: Secrets Rekey

on:
  push:
    paths:
      - '.stackpanel/secrets/recipients/**/*.age.pub'
      - '.stackpanel/secrets/recipients/**/*.ed25519.pub'
  workflow_dispatch:
    inputs:
      public_key:
        description: 'AGE or SSH ED25519 public key (age1... or ssh-ed25519 ...)'
        required: true
      username:
        description: 'Team member name (used for filename)'
        required: true
      group:
        description: 'Recipient group (team or admins)'
        default: 'team'

permissions:
  contents: write

jobs:
  rekey:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          ref: ${{ github.ref }}
          token: ${{ github.token }}

      - name: Install age, sops, and ssh-to-age
        run: |
          AGE_VERSION="1.2.0"
          curl -fsSL "https://github.com/FiloSottile/age/releases/download/v${AGE_VERSION}/age-v${AGE_VERSION}-linux-amd64.tar.gz" | tar xz
          sudo mv age/age age/age-keygen /usr/local/bin/
          SOPS_VERSION="3.9.4"
          curl -fsSL "https://github.com/getsops/sops/releases/download/v${SOPS_VERSION}/sops-v${SOPS_VERSION}.linux.amd64" -o /usr/local/bin/sops
          chmod +x /usr/local/bin/sops
          SSH_TO_AGE_VERSION="1.1.9"
          curl -fsSL "https://github.com/Mic92/ssh-to-age/releases/download/${SSH_TO_AGE_VERSION}/ssh-to-age-linux-amd64" -o /usr/local/bin/ssh-to-age
          chmod +x /usr/local/bin/ssh-to-age

      - name: Add key (manual dispatch only)
        if: github.event_name == 'workflow_dispatch'
        run: |
          .stackpanel/secrets/bin/add-recipient.sh \
            --key "${{ inputs.public_key }}" \
            --name "${{ inputs.username }}" \
            --group "${{ inputs.group }}"

      - name: Rekey
        env:
__ENV_BLOCK__
        run: .stackpanel/secrets/bin/rekey.sh

      - name: Commit and push
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add .stackpanel/secrets/recipients/
          if git diff --cached --quiet; then
            echo "No changes to commit"
          else
            git commit -m "chore(secrets): rekey group keys for updated recipients"
            git push
          fi
