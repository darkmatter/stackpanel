# ==============================================================================
# tui.nix
#
# Delayed TUI (Terminal User Interface) pattern for post-shell-entry prompts.
#
# This module enables interactive prompts that run AFTER the shell becomes
# usable, preventing blocking during shell initialization.
#
# Features:
# - Runs TUI scripts in background with configurable delay
# - Only runs when TTY is available (stdin/stdout)
# - Graceful degradation (no errors if TTY unavailable)
# - Ordered execution with dependency support
# - Debug mode for troubleshooting
#
# Usage:
#   stackpanel.tui.prompts.aws-setup = {
#     enable = true;
#     script = ''
#       if ! check-aws-cert; then
#         gum choose "Setup" "Skip"
#       fi
#     '';
#     delay = 0.5;  # seconds
#     order = 100;
#   };
# ==============================================================================
{
  config,
  lib,
  pkgs,
  ...
}:
let
  cfg = config.stackpanel.tui;
  spCfg = config.stackpanel;

  # Get all enabled prompts sorted by order
  enabledPrompts = lib.filter (p: p.enable) (lib.attrValues cfg.prompts);
  sortedPrompts = lib.sort (a: b: a.order < b.order) enabledPrompts;

  # Generate the TUI runner script
  tuiRunnerScript = pkgs.writeShellScript "stackpanel-tui-runner" ''
    # Stackpanel TUI Runner
    # Runs delayed interactive prompts after shell entry
    # Generated by: nix/stackpanel/devshell/tui.nix

    ${lib.optionalString cfg.debug ''
      _tui_log() {
        echo "[TUI] $*" >&2
      }
    ''}
    ${lib.optionalString (!cfg.debug) ''
      _tui_log() { :; }
    ''}

    _tui_log "Runner started (PID=$$)"

    # Wait for initial delay
    _tui_log "Waiting ${toString cfg.initialDelay}s before checking TTY..."
    sleep ${toString cfg.initialDelay}

    # Check if we have a TTY
    if [[ ! -t 0 ]] || [[ ! -t 1 ]]; then
      _tui_log "No TTY detected (stdin or stdout not a terminal)"
      exit 0
    fi

    _tui_log "TTY detected, running prompts..."

    # Run each prompt in order
    ${lib.concatMapStringsSep "\n\n" (prompt: ''
      # ${prompt.name}
      ${lib.optionalString (prompt.description != null) ''
        _tui_log "Running: ${prompt.description}"
      ''}
      ${lib.optionalString (prompt.delay > 0) ''
        sleep ${toString prompt.delay}
      ''}
      (
        ${prompt.script}
      ) || {
        _tui_log "Warning: ${prompt.name} failed with exit code $?"
      }
    '') sortedPrompts}

    _tui_log "All prompts completed"
  '';

  # The hook content that spawns the background runner
  tuiHookContent = lib.optionalString (enabledPrompts != [ ]) ''
    # Spawn TUI runner in background (non-blocking)
    _tui_pid=$(${tuiRunnerScript} ${
      lib.optionalString (!cfg.debug) ">/dev/null 2>&1"
    } < /dev/null & echo $!)
    ${lib.optionalString cfg.debug ''
      echo "[TUI] Background runner spawned (PID=$_tui_pid)" >&2
    ''}
  '';

in
{
  options.stackpanel.tui = {
    enable = lib.mkEnableOption "TUI (Terminal User Interface) prompts" // {
      default = true;
    };

    debug = lib.mkOption {
      type = lib.types.bool;
      default = false;
      description = ''
        Enable debug logging for TUI runner.
        Shows when prompts run and any errors.
      '';
    };

    initialDelay = lib.mkOption {
      type = lib.types.numbers.positive;
      default = 0.5;
      description = ''
        Initial delay (in seconds) before checking TTY and running prompts.
        This ensures the shell is fully initialized and interactive.
      '';
    };

    prompts = lib.mkOption {
      type = lib.types.attrsOf (
        lib.types.submodule (
          { name, ... }:
          {
            options = {
              name = lib.mkOption {
                type = lib.types.str;
                default = name;
                description = "Unique identifier for this prompt";
              };

              enable = lib.mkEnableOption "this TUI prompt" // {
                default = true;
              };

              description = lib.mkOption {
                type = lib.types.nullOr lib.types.str;
                default = null;
                description = "Human-readable description (shown in debug logs)";
              };

              script = lib.mkOption {
                type = lib.types.lines;
                description = ''
                  Shell script to run for this prompt.

                  The script should:
                  - Check if prompting is needed (cert missing, setup incomplete, etc.)
                  - Show interactive UI (using gum, dialog, etc.)
                  - Handle errors gracefully

                  Exit codes:
                  - 0: Success (or user declined)
                  - Non-zero: Error (logged but doesn't fail shell)
                '';
              };

              delay = lib.mkOption {
                type = lib.types.numbers.nonnegative;
                default = 0;
                description = ''
                  Additional delay (in seconds) before running this specific prompt.
                  Useful for spacing out multiple prompts.
                '';
              };

              order = lib.mkOption {
                type = lib.types.int;
                default = 100;
                description = ''
                  Execution order (lower numbers run first).

                  Suggested ranges:
                  - 0-99: Critical setup (certificates, auth)
                  - 100-199: Services and connections
                  - 200-299: Optional features
                  - 300+: Informational prompts
                '';
              };

              dependencies = lib.mkOption {
                type = lib.types.listOf lib.types.str;
                default = [ ];
                description = ''
                  List of other prompt names that must complete before this one.
                  (Not yet implemented - use 'order' for now)
                '';
              };
            };
          }
        )
      );
      default = { };
      description = "TUI prompts to run after shell entry";
    };
  };

  config = lib.mkIf (spCfg.enable && cfg.enable) {
    # Add TUI runner to shell hooks (runs at the very end)
    stackpanel.devshell.hooks.after = lib.mkAfter [
      tuiHookContent
    ];

    # Export debug flag for runtime checks
    stackpanel.devshell.env.STACKPANEL_TUI_DEBUG = lib.mkIf cfg.debug "1";
  };
}
