{
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "biomejs.biome",
	"biome.enabled": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit",
		"source.organizeImports.biome": "explicit"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[graphql]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"typescript.tsdk": "${workspaceFolder}/node_modules/typescript/lib",
	"editor.formatOnPaste": true,
	"emmet.showExpandedAbbreviation": "never",
	"terminal.integrated.env.osx": {
		"PATH": "${workspaceFolder}/.devenv/profile/bin:${env:PATH}"
	},
	"python.terminal.shellIntegration.enabled": true,
	"terminal.integrated.shellIntegration.enabled": true,
	"terminal.integrated.shellIntegration.environmentReporting": true,
	"files.exclude": {
		"**/.claude": true,
		"**/.codex": true,
		"**/.cursor": true,
		"**/.zed": true,
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true,
		"**/.goosehints": true,
		"**/bts.jsonc": true,
		"**/bun.lock": true,
		"**/devenv.lock": true,
		"**/flake.lock": true
	},
	"biome.lsp.bin": "${workspaceFolder}/node_modules/@biomejs/cli-darwin-arm64/biome",
	"nix.enableLanguageServer": true,
	"nix.serverPath": "nixd",
	"nix.serverSettings": {
		"nixd": {}
	},
	"[nix]": {
		"editor.defaultFormatter": "jnoortheen.nix-ide"
	}
}
