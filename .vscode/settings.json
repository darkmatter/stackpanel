{
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },
  "go.alternateTools": {
    "gopls": "/nix/store/9kig164yjxdpz3prvfkpvxvnx10cz397-gopls-0.20.0/bin/gopls"
  },
  "nix.enableLanguageServer": true,
  "nix.formatterPath": "alejandra",
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nil": {
      "formatting": {
        "command": [
          "alejandra"
        ]
      },
      "nix": {
        "flake": {
          "autoEvalInputs": true,
          "nixpkgsInputName": "nixpkgs"
        },
        "maxMemoryMB": 8192
      },
      "options": {
        "stackpanel": {
          "expr": "(builtins.getFlake \"https://flakehub.com/f/darkmatter/stackpanel/*\").legacyPackages.${builtins.currentSystem}.stackpanelOptions"
        }
      }
    },
    "nixd": {
      "formatting": {
        "command": [
          "nixfmt"
        ]
      },
      "options": {
        "nixos": {
          "expr": "null"
        },
        "sp-app": {
          "expr": "(builtins.getFlake \"https://flakehub.com/f/darkmatter/stackpanel/*\").legacyPackages.${builtins.currentSystem}.stackpanelOptions.apps.type.getSubOptions []"
        },
        "sp-task": {
          "expr": "(builtins.getFlake \"https://flakehub.com/f/darkmatter/stackpanel/*\").legacyPackages.${builtins.currentSystem}.stackpanelOptions.tasks.type.getSubOptions []"
        },
        "sp-user": {
          "expr": "(builtins.getFlake \"https://flakehub.com/f/darkmatter/stackpanel/*\").legacyPackages.${builtins.currentSystem}.stackpanelOptions.users.type.getSubOptions []"
        },
        "stackpanel": {
          "expr": "(builtins.getFlake \"https://flakehub.com/f/darkmatter/stackpanel/*\").legacyPackages.${builtins.currentSystem}.stackpanelOptions"
        }
      }
    }
  },
  "terminal.integrated.defaultProfile.linux": "Devshell",
  "terminal.integrated.defaultProfile.osx": "Devshell",
  "terminal.integrated.profiles.linux": {
    "Devshell": {
      "args": [
        "-c",
        "${workspaceFolder}/.stack/gen/vscode/devshell-loader.sh"
      ],
      "path": "/bin/bash"
    }
  },
  "terminal.integrated.profiles.osx": {
    "Devshell": {
      "args": [
        "-c",
        "${workspaceFolder}/.stack/gen/vscode/devshell-loader.sh"
      ],
      "path": "/bin/bash"
    }
  },
  "terminal.integrated.shellIntegration.enabled": true
}
