#!/usr/bin/env bash
# Quick test runner for stackpanel
# Usage: ./test [smoke|templates|all|devenv|native]

set -euo pipefail

case "${1:-all}" in
  smoke|smoke-test)
    exec ./tests/smoke-test.sh --both
    ;;
  devenv)
    exec ./tests/smoke-test.sh --devenv
    ;;
  native)
    exec ./tests/smoke-test.sh --native
    ;;
  templates)
    exec ./tests/test-templates.sh
    ;;
  all)
    echo "Running all tests..."
    ./tests/smoke-test.sh --both
    ./tests/test-templates.sh
    ;;
  help|--help|-h)
    echo "Usage: ./test [smoke|templates|all|devenv|native]"
    echo ""
    echo "Commands:"
    echo "  smoke      - Run smoke tests (both devenv and native)"
    echo "  devenv     - Test devenv shell only"
    echo "  native     - Test native shell only"
    echo "  templates  - Test all templates"
    echo "  all        - Run all tests (default)"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run './test help' for usage"
    exit 1
    ;;
esac
