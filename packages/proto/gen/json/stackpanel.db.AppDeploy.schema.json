{
  "$id": "stackpanel.db.AppDeploy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Deployment mapping for Colmena (targets, roles, and modules)",
  "patternProperties": {
    "^(nixosModules)$": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "properties": {
    "enable": {
      "default": false,
      "type": "boolean"
    },
    "nixos_modules": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "role": {
      "type": "string"
    },
    "secrets": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "system": {
      "type": "string"
    },
    "targets": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "title": "App Deploy",
  "type": "object"
}
