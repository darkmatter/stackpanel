{
  "$id": "stackpanel.db.Onboarding.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Onboarding configuration for new team members",
  "properties": {
    "auto_run": {
      "type": "boolean"
    },
    "categories": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Category.schema.strict.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "completion_message": {
      "type": "string"
    },
    "enable": {
      "type": "boolean"
    },
    "persist_state": {
      "type": "boolean"
    },
    "state_file": {
      "type": "string"
    },
    "steps": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Step.schema.strict.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "welcome_message": {
      "type": "string"
    }
  },
  "required": [
    "enable",
    "welcome_message",
    "completion_message",
    "auto_run",
    "persist_state",
    "state_file"
  ],
  "title": "Onboarding",
  "type": "object"
}
