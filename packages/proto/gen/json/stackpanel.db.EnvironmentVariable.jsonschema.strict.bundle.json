{
  "$defs": {
    "stackpanel.db.EnvironmentVariable.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Environment variable for this app",
      "properties": {
        "defaultValue": {
          "type": "string"
        },
        "description": {
          "description": "Human-readable description of what this variable is for and where to\n obtain it. Surfaced in the studio Variables UI and in the actionable\n error message thrown by `loadAppEnv(..., { validate: true })` when\n the variable is missing.\n  (example: \"Postgres connection string used by the API server\")",
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "secret": {
          "type": "boolean"
        },
        "sops": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "required",
        "secret"
      ],
      "title": "Environment Variable",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.EnvironmentVariable.jsonschema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.EnvironmentVariable.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
