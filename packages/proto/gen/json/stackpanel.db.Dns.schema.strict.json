{
  "$id": "stackpanel.db.Dns.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "DNS records and domain configuration",
  "properties": {
    "default_ttl": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "zones": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Zone.schema.strict.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    }
  },
  "required": [
    "default_ttl"
  ],
  "title": "Dns",
  "type": "object"
}
