{
  "$defs": {
    "stackpanel.db.HealthSummary.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Overall health summary across all modules",
      "patternProperties": {
        "^(last_updated)$": {
          "default": "",
          "type": "string"
        },
        "^(overall_status)$": {
          "anyOf": [
            {
              "pattern": "^HEALTH_STATUS_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "HEALTH_STATUS_HEALTHY",
                "HEALTH_STATUS_DEGRADED",
                "HEALTH_STATUS_UNHEALTHY",
                "HEALTH_STATUS_UNKNOWN",
                "HEALTH_STATUS_DISABLED"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Health Status"
        },
        "^(total_checks)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "^(total_healthy)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "properties": {
        "lastUpdated": {
          "default": "",
          "type": "string"
        },
        "modules": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.ModuleHealth.jsonschema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "overallStatus": {
          "anyOf": [
            {
              "pattern": "^HEALTH_STATUS_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "HEALTH_STATUS_HEALTHY",
                "HEALTH_STATUS_DEGRADED",
                "HEALTH_STATUS_UNHEALTHY",
                "HEALTH_STATUS_UNKNOWN",
                "HEALTH_STATUS_DISABLED"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Health Status"
        },
        "totalChecks": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "totalHealthy": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "title": "Health Summary",
      "type": "object"
    },
    "stackpanel.db.HealthcheckResult.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "The result of executing a healthcheck",
      "patternProperties": {
        "^(check_id)$": {
          "default": "",
          "type": "string"
        },
        "^(duration_ms)$": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "properties": {
        "checkId": {
          "default": "",
          "type": "string"
        },
        "durationMs": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "error": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "status": {
          "anyOf": [
            {
              "pattern": "^HEALTH_STATUS_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "HEALTH_STATUS_HEALTHY",
                "HEALTH_STATUS_DEGRADED",
                "HEALTH_STATUS_UNHEALTHY",
                "HEALTH_STATUS_UNKNOWN",
                "HEALTH_STATUS_DISABLED"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Health Status"
        },
        "timestamp": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Healthcheck Result",
      "type": "object"
    },
    "stackpanel.db.ModuleHealth.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Aggregated health status for a module",
      "patternProperties": {
        "^(healthy_count)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "^(last_updated)$": {
          "default": "",
          "type": "string"
        },
        "^(total_count)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "properties": {
        "checks": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.HealthcheckResult.jsonschema.json"
          },
          "type": "array"
        },
        "healthyCount": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "lastUpdated": {
          "default": "",
          "type": "string"
        },
        "module": {
          "default": "",
          "type": "string"
        },
        "status": {
          "anyOf": [
            {
              "pattern": "^HEALTH_STATUS_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "HEALTH_STATUS_HEALTHY",
                "HEALTH_STATUS_DEGRADED",
                "HEALTH_STATUS_UNHEALTHY",
                "HEALTH_STATUS_UNKNOWN",
                "HEALTH_STATUS_DISABLED"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Health Status"
        },
        "totalCount": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "title": "Module Health",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.HealthSummary.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.HealthSummary.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
