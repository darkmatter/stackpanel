{
  "$id": "stackpanel.db.Healthcheck.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A healthcheck definition that can verify module functionality",
  "properties": {
    "description": {
      "type": "string"
    },
    "http_expected_status": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "http_method": {
      "type": "string"
    },
    "http_url": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "interval_seconds": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "module": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "nix_expr": {
      "type": "string"
    },
    "script_bin_path": {
      "type": "string"
    },
    "script_source": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "HEALTHCHECK_SEVERITY_UNSPECIFIED",
        "HEALTHCHECK_SEVERITY_CRITICAL",
        "HEALTHCHECK_SEVERITY_WARNING",
        "HEALTHCHECK_SEVERITY_INFO"
      ],
      "title": "Healthcheck Severity",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "tcp_host": {
      "type": "string"
    },
    "tcp_port": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "timeout_seconds": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "type": {
      "enum": [
        "HEALTHCHECK_TYPE_UNSPECIFIED",
        "HEALTHCHECK_TYPE_SCRIPT",
        "HEALTHCHECK_TYPE_NIX",
        "HEALTHCHECK_TYPE_HTTP",
        "HEALTHCHECK_TYPE_TCP"
      ],
      "title": "Healthcheck Type",
      "type": "string"
    }
  },
  "required": [
    "id",
    "name",
    "type",
    "severity",
    "timeout_seconds",
    "module"
  ],
  "title": "Healthcheck",
  "type": "object"
}
