{
  "$defs": {
    "stackpanel.db.StepCa.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Step CA certificate management configuration for local HTTPS",
      "properties": {
        "config": {
          "$ref": "#/$defs/stackpanel.db.StepCaConfig.jsonschema.strict.json"
        }
      },
      "title": "Step Ca",
      "type": "object"
    },
    "stackpanel.db.StepCaConfig.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Step CA certificate management configuration",
      "properties": {
        "caFingerprint": {
          "type": "string"
        },
        "caUrl": {
          "type": "string"
        },
        "certName": {
          "type": "string"
        },
        "enable": {
          "type": "boolean"
        },
        "promptOnShell": {
          "type": "boolean"
        },
        "provisioner": {
          "type": "string"
        }
      },
      "required": [
        "enable",
        "caUrl",
        "caFingerprint",
        "provisioner",
        "certName",
        "promptOnShell"
      ],
      "title": "Step Ca Config",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.StepCa.jsonschema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.StepCa.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
