{
  "$defs": {
    "stackpanel.db.CloudflareGlobalConfig.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Cloudflare global settings",
      "properties": {
        "account_id": {
          "type": "string"
        },
        "compatibility_date": {
          "type": "string"
        },
        "default_route": {
          "type": "string"
        }
      },
      "required": [
        "compatibility_date"
      ],
      "title": "Cloudflare Global Config",
      "type": "object"
    },
    "stackpanel.db.Deployment.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Global deployment configuration",
      "properties": {
        "cloudflare": {
          "$ref": "#/$defs/stackpanel.db.CloudflareGlobalConfig.schema.strict.json"
        },
        "default_provider": {
          "enum": [
            "DEPLOYMENT_PROVIDER_UNSPECIFIED",
            "DEPLOYMENT_PROVIDER_CLOUDFLARE",
            "DEPLOYMENT_PROVIDER_FLY",
            "DEPLOYMENT_PROVIDER_AWS_ECS",
            "DEPLOYMENT_PROVIDER_RAILWAY",
            "DEPLOYMENT_PROVIDER_RENDER"
          ],
          "title": "Deployment Provider",
          "type": "string"
        },
        "fly": {
          "$ref": "#/$defs/stackpanel.db.FlyGlobalConfig.schema.strict.json"
        }
      },
      "required": [
        "default_provider"
      ],
      "title": "Deployment",
      "type": "object"
    },
    "stackpanel.db.FlyGlobalConfig.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Fly.io global settings",
      "properties": {
        "default_region": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "registry_prefix": {
          "type": "string"
        }
      },
      "required": [
        "default_region",
        "registry_prefix"
      ],
      "title": "Fly Global Config",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Deployment.schema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Deployment.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
