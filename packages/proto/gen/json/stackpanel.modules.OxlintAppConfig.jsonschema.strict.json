{
  "$id": "stackpanel.modules.OxlintAppConfig.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "OxLint per-app linting configuration",
  "properties": {
    "categories": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "configPath": {
      "type": "string"
    },
    "enable": {
      "type": "boolean"
    },
    "fix": {
      "type": "boolean"
    },
    "gitHook": {
      "type": "boolean"
    },
    "ignorePatterns": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "paths": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "plugins": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "rules": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "turboTask": {
      "type": "boolean"
    }
  },
  "required": [
    "enable",
    "fix",
    "gitHook",
    "turboTask"
  ],
  "title": "Oxlint App Config",
  "type": "object"
}
