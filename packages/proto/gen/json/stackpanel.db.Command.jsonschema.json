{
  "$id": "stackpanel.db.Command.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A workspace command definition",
  "patternProperties": {
    "^(config_arg)$": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "^(config_path)$": {
      "type": "string"
    }
  },
  "properties": {
    "args": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "bin": {
      "type": "string"
    },
    "configArg": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "configPath": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "env": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "package": {
      "default": "",
      "type": "string"
    }
  },
  "title": "Command",
  "type": "object"
}
