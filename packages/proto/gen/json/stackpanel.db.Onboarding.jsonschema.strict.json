    },
    "categories": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Category.jsonschema.strict.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "completionMessage": {
      "type": "string"
    },
    "enable": {
      "type": "boolean"
    },
    "persistState": {
      "type": "boolean"
    },
    "stateFile": {
      "type": "string"
    },
    "steps": {
