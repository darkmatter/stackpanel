{
  "$defs": {
    "stackpanel.db.Alias.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Shell alias configuration",
      "properties": {
        "command": {
          "default": "",
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "title": "Alias",
      "type": "object"
    },
    "stackpanel.db.EnvVar.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Environment variable configuration",
      "properties": {
        "description": {
          "type": "string"
        },
        "secret": {
          "default": false,
          "type": "boolean"
        },
        "value": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Env Var",
      "type": "object"
    },
    "stackpanel.db.Profile.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Shell profile configuration",
      "patternProperties": {
        "^(history_ignore)$": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "^(history_size)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "^(init_extra)$": {
          "type": "string"
        }
      },
      "properties": {
        "aliases": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Alias.jsonschema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "env": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.EnvVar.jsonschema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "historyIgnore": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "historySize": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "initExtra": {
          "type": "string"
        }
      },
      "title": "Profile",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Profile.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Profile.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
