{
  "$defs": {
    "stackpanel.db.Aws.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "AWS configuration including Roles Anywhere for certificate-based authentication",
      "patternProperties": {
        "^(default_profile)$": {
          "default": "",
          "type": "string"
        },
        "^(extra_config)$": {
          "default": "",
          "type": "string"
        },
        "^(roles_anywhere)$": {
          "$ref": "#/$defs/stackpanel.db.RolesAnywhere.jsonschema.json"
        }
      },
      "properties": {
        "defaultProfile": {
          "default": "",
          "type": "string"
        },
        "extraConfig": {
          "default": "",
          "type": "string"
        },
        "rolesAnywhere": {
          "$ref": "#/$defs/stackpanel.db.RolesAnywhere.jsonschema.json"
        }
      },
      "title": "Aws",
      "type": "object"
    },
    "stackpanel.db.RolesAnywhere.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "AWS Roles Anywhere configuration for certificate-based authentication",
      "patternProperties": {
        "^(account_id)$": {
          "default": "",
          "type": "string"
        },
        "^(cache_buffer_seconds)$": {
          "default": "",
          "type": "string"
        },
        "^(profile_arn)$": {
          "default": "",
          "type": "string"
        },
        "^(prompt_on_shell)$": {
          "default": false,
          "type": "boolean"
        },
        "^(role_name)$": {
          "default": "",
          "type": "string"
        },
        "^(trust_anchor_arn)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "accountId": {
          "default": "",
          "type": "string"
        },
        "cacheBufferSeconds": {
          "default": "",
          "type": "string"
        },
        "enable": {
          "default": false,
          "type": "boolean"
        },
        "profileArn": {
          "default": "",
          "type": "string"
        },
        "promptOnShell": {
          "default": false,
          "type": "boolean"
        },
        "region": {
          "default": "",
          "type": "string"
        },
        "roleName": {
          "default": "",
          "type": "string"
        },
        "trustAnchorArn": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Roles Anywhere",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Aws.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Aws.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
