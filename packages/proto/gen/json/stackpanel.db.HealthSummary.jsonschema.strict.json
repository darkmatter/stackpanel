{
  "$id": "stackpanel.db.HealthSummary.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Overall health summary across all modules",
  "properties": {
    "lastUpdated": {
      "type": "string"
    },
    "modules": {
      "additionalProperties": {
        "$ref": "stackpanel.db.ModuleHealth.jsonschema.strict.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "overallStatus": {
      "enum": [
        "HEALTH_STATUS_UNSPECIFIED",
        "HEALTH_STATUS_HEALTHY",
        "HEALTH_STATUS_DEGRADED",
        "HEALTH_STATUS_UNHEALTHY",
        "HEALTH_STATUS_UNKNOWN",
        "HEALTH_STATUS_DISABLED"
      ],
      "title": "Health Status",
      "type": "string"
    },
    "totalChecks": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "totalHealthy": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    }
  },
  "required": [
    "overallStatus",
    "totalHealthy",
    "totalChecks",
    "lastUpdated"
  ],
  "title": "Health Summary",
  "type": "object"
}
