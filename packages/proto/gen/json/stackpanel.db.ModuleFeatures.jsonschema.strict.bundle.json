      "required": [
        "files",
        "scripts",
        "tasks",
        "healthchecks",
        "services",
        "secrets",
        "packages",
        "appModule"
      ],
      "title": "Module Features",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.ModuleFeatures.jsonschema.strict.bundle.json",
