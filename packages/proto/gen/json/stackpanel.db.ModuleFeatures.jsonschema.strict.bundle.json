      "additionalProperties": false,
      "description": "Which stackpanel features this module uses",
      "properties": {
        "appModule": {
          "type": "boolean"
        },
        "files": {
          "type": "boolean"
        },
        "healthchecks": {
          "type": "boolean"
        },
        "packages": {
          "type": "boolean"
        },
        "scripts": {
          "type": "boolean"
        },
        "secrets": {
          "type": "boolean"
        },
        "services": {
          "type": "boolean"
        },
        "tasks": {
          "type": "boolean"
        }
