{
  "$id": "stackpanel.db.FlyAppConfig.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Fly.io per-app deployment configuration",
  "patternProperties": {
    "^(app_name)$": {
      "default": "",
      "type": "string"
    },
    "^(auto_start)$": {
      "default": false,
      "type": "boolean"
    },
    "^(auto_stop)$": {
      "anyOf": [
        {
          "pattern": "^FLY_AUTO_STOP_UNSPECIFIED$",
          "type": "string"
        },
        {
          "enum": [
            "FLY_AUTO_STOP_OFF",
            "FLY_AUTO_STOP_STOP",
            "FLY_AUTO_STOP_SUSPEND"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "default": 0,
      "title": "Fly Auto Stop"
    },
    "^(cpu_kind)$": {
      "anyOf": [
        {
          "pattern": "^FLY_MACHINE_CPU_KIND_UNSPECIFIED$",
          "type": "string"
        },
        {
          "enum": [
            "FLY_MACHINE_CPU_KIND_SHARED",
            "FLY_MACHINE_CPU_KIND_PERFORMANCE"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "default": 0,
      "title": "Fly Machine Cpu Kind"
    },
    "^(force_https)$": {
      "default": false,
      "type": "boolean"
    },
    "^(health_check_interval)$": {
      "type": "string"
    },
    "^(health_check_path)$": {
      "type": "string"
    },
    "^(min_machines)$": {
      "anyOf": [
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "default": 0
    }
  },
  "properties": {
    "appName": {
      "default": "",
      "type": "string"
    },
    "autoStart": {
      "default": false,
      "type": "boolean"
    },
    "autoStop": {
      "anyOf": [
        {
          "pattern": "^FLY_AUTO_STOP_UNSPECIFIED$",
          "type": "string"
        },
        {
          "enum": [
            "FLY_AUTO_STOP_OFF",
            "FLY_AUTO_STOP_STOP",
            "FLY_AUTO_STOP_SUSPEND"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "default": 0,
      "title": "Fly Auto Stop"
    },
    "cpuKind": {
      "anyOf": [
        {
          "pattern": "^FLY_MACHINE_CPU_KIND_UNSPECIFIED$",
          "type": "string"
        },
        {
          "enum": [
            "FLY_MACHINE_CPU_KIND_SHARED",
            "FLY_MACHINE_CPU_KIND_PERFORMANCE"
          ],
          "type": "string"
        },
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      ],
      "default": 0,
      "title": "Fly Machine Cpu Kind"
    },
    "cpus": {
      "anyOf": [
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "default": 0
    },
    "env": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "forceHttps": {
      "default": false,
      "type": "boolean"
    },
    "healthCheckInterval": {
      "type": "string"
    },
    "healthCheckPath": {
      "type": "string"
    },
    "memory": {
      "default": "",
      "type": "string"
    },
    "minMachines": {
      "anyOf": [
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "default": 0
    },
    "region": {
      "default": "",
      "type": "string"
    },
    "secrets": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "title": "Fly App Config",
  "type": "object"
}
