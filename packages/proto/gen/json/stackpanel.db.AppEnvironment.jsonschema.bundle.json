{
  "$defs": {
    "stackpanel.db.AppEnvironment.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Environment configuration (e.g., dev, staging, production)",
      "properties": {
        "description": {
          "type": "string"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Environment variables for this environment.\n Key: Environment variable name (e.g., DATABASE_URL)\n Value: Literal string or vals reference (e.g., ref+sops://...)",
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "extends": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "name": {
          "default": "",
          "type": "string"
        }
      },
      "title": "App Environment",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.AppEnvironment.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.AppEnvironment.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
