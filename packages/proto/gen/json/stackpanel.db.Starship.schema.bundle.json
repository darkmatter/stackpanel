{
  "$defs": {
    "stackpanel.db.Starship.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Starship prompt configuration",
      "patternProperties": {
        "^(addNewline)$": {
          "default": false,
          "type": "boolean"
        },
        "^(commandTimeout)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "^(continuationPrompt)$": {
          "default": "",
          "type": "string"
        },
        "^(rightFormat)$": {
          "type": "string"
        },
        "^(scanTimeout)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "properties": {
        "add_newline": {
          "default": false,
          "type": "boolean"
        },
        "command_timeout": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "continuation_prompt": {
          "default": "",
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "right_format": {
          "type": "string"
        },
        "scan_timeout": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "title": "Starship",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Starship.schema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Starship.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
