{
  "$id": "stackpanel.db.Dns.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "DNS records and domain configuration",
  "patternProperties": {
    "^(defaultTtl)$": {
      "anyOf": [
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "default": 0
    }
  },
  "properties": {
    "default_ttl": {
      "anyOf": [
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "default": 0
    },
    "zones": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Zone.schema.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    }
  },
  "title": "Dns",
  "type": "object"
}
