{
  "$defs": {
    "stackpanel.db.Extension.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Extension configuration and metadata",
      "properties": {
        "apps": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.ExtensionAppData.schema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "builtin": {
          "default": false,
          "type": "boolean"
        },
        "category": {
          "anyOf": [
            {
              "pattern": "^EXTENSION_CATEGORY_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "EXTENSION_CATEGORY_INFRASTRUCTURE",
                "EXTENSION_CATEGORY_CI_CD",
                "EXTENSION_CATEGORY_DATABASE",
                "EXTENSION_CATEGORY_SECRETS",
                "EXTENSION_CATEGORY_DEPLOYMENT",
                "EXTENSION_CATEGORY_DEVELOPMENT",
                "EXTENSION_CATEGORY_MONITORING",
                "EXTENSION_CATEGORY_INTEGRATION"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Extension Category"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "default": false,
          "type": "boolean"
        },
        "features": {
          "$ref": "#/$defs/stackpanel.db.ExtensionFeatures.schema.json"
        },
        "name": {
          "default": "",
          "type": "string"
        },
        "panels": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ExtensionPanel.schema.json"
          },
          "type": "array"
        },
        "priority": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "source": {
          "$ref": "#/$defs/stackpanel.db.ExtensionSource.schema.json"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "version": {
          "type": "string"
        }
      },
      "title": "Extension",
      "type": "object"
    },
    "stackpanel.db.ExtensionAppData.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Extension data specific to an application",
      "properties": {
        "config": {
          "additionalProperties": {
            "type": "string"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "enabled": {
          "default": false,
          "type": "boolean"
        }
      },
      "title": "Extension App Data",
      "type": "object"
    },
    "stackpanel.db.ExtensionFeatures.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Flags indicating which core stackpanel features this extension configures",
      "patternProperties": {
        "^(shellHooks)$": {
          "default": false,
          "type": "boolean"
        }
      },
      "properties": {
        "checks": {
          "default": false,
          "type": "boolean"
        },
        "files": {
          "default": false,
          "type": "boolean"
        },
        "packages": {
          "default": false,
          "type": "boolean"
        },
        "scripts": {
          "default": false,
          "type": "boolean"
        },
        "secrets": {
          "default": false,
          "type": "boolean"
        },
        "services": {
          "default": false,
          "type": "boolean"
        },
        "shell_hooks": {
          "default": false,
          "type": "boolean"
        },
        "tasks": {
          "default": false,
          "type": "boolean"
        }
      },
      "title": "Extension Features",
      "type": "object"
    },
    "stackpanel.db.ExtensionPanel.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "UI panel configuration for the web interface",
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.PanelField.schema.json"
          },
          "type": "array"
        },
        "id": {
          "default": "",
          "type": "string"
        },
        "order": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "title": {
          "default": "",
          "type": "string"
        },
        "type": {
          "anyOf": [
            {
              "pattern": "^PANEL_TYPE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "PANEL_TYPE_STATUS",
                "PANEL_TYPE_APPS_GRID",
                "PANEL_TYPE_FORM",
                "PANEL_TYPE_TABLE",
                "PANEL_TYPE_CUSTOM"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Panel Type"
        }
      },
      "title": "Extension Panel",
      "type": "object"
    },
    "stackpanel.db.ExtensionSource.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Extension source configuration",
      "patternProperties": {
        "^(modulePath)$": {
          "type": "string"
        }
      },
      "properties": {
        "module_path": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "type": {
          "anyOf": [
            {
              "pattern": "^EXTENSION_SOURCE_TYPE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "EXTENSION_SOURCE_TYPE_BUILTIN",
                "EXTENSION_SOURCE_TYPE_LOCAL",
                "EXTENSION_SOURCE_TYPE_GITHUB",
                "EXTENSION_SOURCE_TYPE_NPM",
                "EXTENSION_SOURCE_TYPE_URL"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Extension Source Type"
        },
        "url": {
          "type": "string"
        }
      },
      "title": "Extension Source",
      "type": "object"
    },
    "stackpanel.db.Extensions.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Extensions and plugins configuration",
      "patternProperties": {
        "^(autoUpdate)$": {
          "default": false,
          "type": "boolean"
        }
      },
      "properties": {
        "auto_update": {
          "default": false,
          "type": "boolean"
        },
        "enabled": {
          "default": false,
          "type": "boolean"
        },
        "extensions": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Extension.schema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "registry": {
          "type": "string"
        }
      },
      "title": "Extensions",
      "type": "object"
    },
    "stackpanel.db.PanelField.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Configuration field for a panel",
      "properties": {
        "name": {
          "default": "",
          "type": "string"
        },
        "options": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "anyOf": [
            {
              "pattern": "^FIELD_TYPE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "FIELD_TYPE_STRING",
                "FIELD_TYPE_NUMBER",
                "FIELD_TYPE_BOOLEAN",
                "FIELD_TYPE_SELECT",
                "FIELD_TYPE_MULTISELECT",
                "FIELD_TYPE_APP_FILTER",
                "FIELD_TYPE_COLUMNS",
                "FIELD_TYPE_JSON"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Field Type"
        },
        "value": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Panel Field",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Extensions.schema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Extensions.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
