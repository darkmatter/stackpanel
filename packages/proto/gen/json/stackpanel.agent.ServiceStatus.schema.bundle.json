{
  "$defs": {
    "stackpanel.agent.ServiceStatus.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "name": {
          "default": "",
          "type": "string"
        },
        "pid": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "status": {
          "default": "",
          "type": "string"
        },
        "uptime": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "title": "Service Status",
      "type": "object"
    }
  },
  "$id": "stackpanel.agent.ServiceStatus.schema.bundle.json",
  "$ref": "#/$defs/stackpanel.agent.ServiceStatus.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
