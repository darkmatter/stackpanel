{
  "$id": "stackpanel.db.Onboarding.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Onboarding configuration for new team members",
  "patternProperties": {
    "^(autoRun)$": {
      "default": false,
      "type": "boolean"
    },
    "^(completionMessage)$": {
      "default": "",
      "type": "string"
    },
    "^(persistState)$": {
      "default": false,
      "type": "boolean"
    },
    "^(stateFile)$": {
      "default": "",
      "type": "string"
    },
    "^(welcomeMessage)$": {
      "default": "",
      "type": "string"
    }
  },
  "properties": {
    "auto_run": {
      "default": false,
      "type": "boolean"
    },
    "categories": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Category.schema.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "completion_message": {
      "default": "",
      "type": "string"
    },
    "enable": {
      "default": false,
      "type": "boolean"
    },
    "persist_state": {
      "default": false,
      "type": "boolean"
    },
    "state_file": {
      "default": "",
      "type": "string"
    },
    "steps": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Step.schema.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "welcome_message": {
      "default": "",
      "type": "string"
    }
  },
  "title": "Onboarding",
  "type": "object"
}
