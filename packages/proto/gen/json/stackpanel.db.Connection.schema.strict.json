{
  "$id": "stackpanel.db.Connection.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Database connection settings",
  "properties": {
    "database": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "password_env": {
      "type": "string"
    },
    "port": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "ssl": {
      "type": "boolean"
    },
    "ssl_mode": {
      "enum": [
        "SSL_MODE_UNSPECIFIED",
        "SSL_MODE_DISABLE",
        "SSL_MODE_ALLOW",
        "SSL_MODE_PREFER",
        "SSL_MODE_REQUIRE",
        "SSL_MODE_VERIFY_CA",
        "SSL_MODE_VERIFY_FULL"
      ],
      "title": "SSL Mode",
      "type": "string"
    },
    "username": {
      "type": "string"
    }
  },
  "required": [
    "host",
    "port",
    "database",
    "username",
    "ssl",
    "ssl_mode"
  ],
  "title": "Connection",
  "type": "object"
}
