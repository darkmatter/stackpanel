{
  "$defs": {
    "stackpanel.db.User.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A team member with access to the project",
      "properties": {
        "email": {
          "type": "string"
        },
        "github": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "publicKeys": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "secretsAllowedEnvironments": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "name"
      ],
      "title": "User",
      "type": "object"
    },
    "stackpanel.db.Users.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Map of username to user configuration",
      "properties": {
        "users": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.User.jsonschema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "title": "Users",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Users.jsonschema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Users.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
