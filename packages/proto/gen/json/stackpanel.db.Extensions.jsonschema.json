{
  "$id": "stackpanel.db.Extensions.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Extensions and plugins configuration",
  "patternProperties": {
    "^(auto_update)$": {
      "default": false,
      "type": "boolean"
    }
  },
  "properties": {
    "autoUpdate": {
      "default": false,
      "type": "boolean"
    },
    "enabled": {
      "default": false,
      "type": "boolean"
    },
    "extensions": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Extension.jsonschema.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "registry": {
      "type": "string"
    }
  },
  "title": "Extensions",
  "type": "object"
}
