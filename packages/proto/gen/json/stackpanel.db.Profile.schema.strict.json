{
  "$id": "stackpanel.db.Profile.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Shell profile configuration",
  "properties": {
    "aliases": {
      "additionalProperties": {
        "$ref": "stackpanel.db.Alias.schema.strict.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "env": {
      "additionalProperties": {
        "$ref": "stackpanel.db.EnvVar.schema.strict.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "history_ignore": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "history_size": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "init_extra": {
      "type": "string"
    }
  },
  "required": [
    "history_size"
  ],
  "title": "Profile",
  "type": "object"
}
