{
  "$id": "stackpanel.db.Deployment.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Global deployment configuration",
  "properties": {
    "cloudflare": {
      "$ref": "stackpanel.db.CloudflareGlobalConfig.schema.strict.json"
    },
    "default_provider": {
      "enum": [
        "DEPLOYMENT_PROVIDER_UNSPECIFIED",
        "DEPLOYMENT_PROVIDER_CLOUDFLARE",
        "DEPLOYMENT_PROVIDER_FLY",
        "DEPLOYMENT_PROVIDER_AWS_ECS",
        "DEPLOYMENT_PROVIDER_RAILWAY",
        "DEPLOYMENT_PROVIDER_RENDER"
      ],
      "title": "Deployment Provider",
      "type": "string"
    },
    "fly": {
      "$ref": "stackpanel.db.FlyGlobalConfig.schema.strict.json"
    }
  },
  "required": [
    "default_provider"
  ],
  "title": "Deployment",
  "type": "object"
}
