{
  "$defs": {
    "stackpanel.db.Alias.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Shell alias configuration",
      "properties": {
        "command": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "command"
      ],
      "title": "Alias",
      "type": "object"
    },
    "stackpanel.db.EnvVar.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Environment variable configuration",
      "properties": {
        "description": {
          "type": "string"
        },
        "secret": {
          "type": "boolean"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "value",
        "secret"
      ],
      "title": "Env Var",
      "type": "object"
    },
    "stackpanel.db.Profile.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Shell profile configuration",
      "properties": {
        "aliases": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Alias.jsonschema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "env": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.EnvVar.jsonschema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "historyIgnore": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "historySize": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "initExtra": {
          "type": "string"
        }
      },
      "required": [
        "historySize"
      ],
      "title": "Profile",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Profile.jsonschema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Profile.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
