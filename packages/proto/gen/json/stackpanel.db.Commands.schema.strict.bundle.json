{
  "$defs": {
    "stackpanel.db.Command.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A workspace command definition",
      "properties": {
        "args": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "bin": {
          "type": "string"
        },
        "config_arg": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "config_path": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "package": {
          "type": "string"
        }
      },
      "required": [
        "package"
      ],
      "title": "Command",
      "type": "object"
    },
    "stackpanel.db.Commands.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Primary workspace commands configuration",
      "properties": {
        "commands": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Command.schema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "title": "Commands",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Commands.schema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Commands.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
