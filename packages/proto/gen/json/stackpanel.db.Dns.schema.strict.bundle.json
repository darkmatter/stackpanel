{
  "$defs": {
    "stackpanel.db.Dns.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "DNS records and domain configuration",
      "properties": {
        "default_ttl": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "zones": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Zone.schema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "required": [
        "default_ttl"
      ],
      "title": "Dns",
      "type": "object"
    },
    "stackpanel.db.Record.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "DNS record configuration",
      "properties": {
        "comment": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "priority": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "proxied": {
          "type": "boolean"
        },
        "ttl": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "type": {
          "enum": [
            "RECORD_TYPE_UNSPECIFIED",
            "RECORD_TYPE_A",
            "RECORD_TYPE_AAAA",
            "RECORD_TYPE_CNAME",
            "RECORD_TYPE_TXT",
            "RECORD_TYPE_MX",
            "RECORD_TYPE_NS",
            "RECORD_TYPE_SRV",
            "RECORD_TYPE_CAA"
          ],
          "title": "Record Type",
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "name",
        "value",
        "ttl",
        "proxied"
      ],
      "title": "Record",
      "type": "object"
    },
    "stackpanel.db.Zone.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "DNS zone configuration",
      "properties": {
        "domain": {
          "type": "string"
        },
        "managed": {
          "type": "boolean"
        },
        "provider": {
          "enum": [
            "DNS_PROVIDER_UNSPECIFIED",
            "DNS_PROVIDER_CLOUDFLARE",
            "DNS_PROVIDER_ROUTE53",
            "DNS_PROVIDER_NAMECHEAP",
            "DNS_PROVIDER_DIGITALOCEAN",
            "DNS_PROVIDER_MANUAL"
          ],
          "title": "Dns Provider",
          "type": "string"
        },
        "records": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.Record.schema.strict.json"
          },
          "type": "array"
        },
        "zone_id": {
          "type": "string"
        }
      },
      "required": [
        "domain",
        "provider",
        "managed"
      ],
      "title": "Zone",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Dns.schema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Dns.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
