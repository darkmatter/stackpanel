{
  "$defs": {
    "stackpanel.db.Connection.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Database connection settings",
      "patternProperties": {
        "^(passwordEnv)$": {
          "type": "string"
        },
        "^(sslMode)$": {
          "anyOf": [
            {
              "pattern": "^SSL_MODE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "SSL_MODE_DISABLE",
                "SSL_MODE_ALLOW",
                "SSL_MODE_PREFER",
                "SSL_MODE_REQUIRE",
                "SSL_MODE_VERIFY_CA",
                "SSL_MODE_VERIFY_FULL"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "SSL Mode"
        }
      },
      "properties": {
        "database": {
          "default": "",
          "type": "string"
        },
        "host": {
          "default": "",
          "type": "string"
        },
        "password_env": {
          "type": "string"
        },
        "port": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "ssl": {
          "default": false,
          "type": "boolean"
        },
        "ssl_mode": {
          "anyOf": [
            {
              "pattern": "^SSL_MODE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "SSL_MODE_DISABLE",
                "SSL_MODE_ALLOW",
                "SSL_MODE_PREFER",
                "SSL_MODE_REQUIRE",
                "SSL_MODE_VERIFY_CA",
                "SSL_MODE_VERIFY_FULL"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "SSL Mode"
        },
        "username": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Connection",
      "type": "object"
    },
    "stackpanel.db.DatabaseInstance.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Database instance configuration for a specific environment",
      "patternProperties": {
        "^(autoMigrate)$": {
          "default": false,
          "type": "boolean"
        },
        "^(migrationsPath)$": {
          "default": "",
          "type": "string"
        },
        "^(seedsPath)$": {
          "type": "string"
        }
      },
      "properties": {
        "auto_migrate": {
          "default": false,
          "type": "boolean"
        },
        "connection": {
          "$ref": "#/$defs/stackpanel.db.Connection.schema.json"
        },
        "migrations_path": {
          "default": "",
          "type": "string"
        },
        "pool": {
          "$ref": "#/$defs/stackpanel.db.Pool.schema.json"
        },
        "seeds_path": {
          "type": "string"
        },
        "type": {
          "anyOf": [
            {
              "pattern": "^DATABASE_TYPE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "DATABASE_TYPE_POSTGRESQL",
                "DATABASE_TYPE_MYSQL",
                "DATABASE_TYPE_SQLITE",
                "DATABASE_TYPE_MONGODB"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Database Type"
        }
      },
      "title": "Database Instance",
      "type": "object"
    },
    "stackpanel.db.Databases.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Database connection and configuration settings",
      "properties": {
        "databases": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.DatabaseInstance.schema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "default": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Databases",
      "type": "object"
    },
    "stackpanel.db.Pool.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Connection pool settings",
      "patternProperties": {
        "^(connectionTimeout)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "^(idleTimeout)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "properties": {
        "connection_timeout": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "idle_timeout": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "max": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "min": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "title": "Pool",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Databases.schema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Databases.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
