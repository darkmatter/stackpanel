{
  "$defs": {
    "stackpanel.db.Caddy.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Caddy reverse proxy configuration",
      "properties": {
        "enable": {
          "default": false,
          "type": "boolean"
        },
        "sites": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.CaddySite.schema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "title": "Caddy",
      "type": "object"
    },
    "stackpanel.db.CaddySite.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Caddy site configuration",
      "properties": {
        "tls": {
          "default": false,
          "type": "boolean"
        },
        "upstream": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Caddy Site",
      "type": "object"
    },
    "stackpanel.db.Minio.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Minio S3-compatible service configuration",
      "patternProperties": {
        "^(consolePort)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ]
        }
      },
      "properties": {
        "buckets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "console_port": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ]
        },
        "enable": {
          "default": false,
          "type": "boolean"
        },
        "port": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ]
        }
      },
      "title": "Minio",
      "type": "object"
    },
    "stackpanel.db.Postgres.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "PostgreSQL service configuration",
      "properties": {
        "databases": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "enable": {
          "default": false,
          "type": "boolean"
        },
        "extensions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "port": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ]
        },
        "version": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Postgres",
      "type": "object"
    },
    "stackpanel.db.Redis.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Redis service configuration",
      "patternProperties": {
        "^(maxmemoryPolicy)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "enable": {
          "default": false,
          "type": "boolean"
        },
        "maxmemory": {
          "default": "",
          "type": "string"
        },
        "maxmemory_policy": {
          "default": "",
          "type": "string"
        },
        "port": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ]
        }
      },
      "title": "Redis",
      "type": "object"
    },
    "stackpanel.db.Services.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Global development services configuration",
      "patternProperties": {
        "^(projectName)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "caddy": {
          "$ref": "#/$defs/stackpanel.db.Caddy.schema.json"
        },
        "minio": {
          "$ref": "#/$defs/stackpanel.db.Minio.schema.json"
        },
        "postgres": {
          "$ref": "#/$defs/stackpanel.db.Postgres.schema.json"
        },
        "project_name": {
          "default": "",
          "type": "string"
        },
        "redis": {
          "$ref": "#/$defs/stackpanel.db.Redis.schema.json"
        }
      },
      "title": "Services",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Services.schema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Services.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
