{
  "$id": "stackpanel.db.Module.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Configuration for a stackpanel module",
  "properties": {
    "apps": {
      "additionalProperties": {
        "$ref": "stackpanel.db.ModuleAppData.schema.strict.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "config_schema": {
      "description": "JSON Schema for generating configuration forms.\n Describes the module's configurable options.",
      "type": "string"
    },
    "conflicts": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "enable": {
      "type": "boolean"
    },
    "features": {
      "$ref": "stackpanel.db.ModuleFeatures.schema.strict.json"
    },
    "healthcheck_module": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "meta": {
      "$ref": "stackpanel.db.ModuleMeta.schema.strict.json"
    },
    "panels": {
      "items": {
        "$ref": "stackpanel.db.ModulePanel.schema.strict.json"
      },
      "type": "array"
    },
    "priority": {
      "maximum": 2147483647,
      "minimum": -2147483648,
      "type": "integer"
    },
    "requires": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "settings": {
      "additionalProperties": {
        "type": "string"
      },
      "description": "Module-level settings (key-value pairs).\n These are passed to the Nix module configuration.",
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "source": {
      "$ref": "stackpanel.db.ModuleSource.schema.strict.json"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "id",
    "enable",
    "priority"
  ],
  "title": "Module",
  "type": "object"
}
