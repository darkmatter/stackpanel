{
  "$id": "stackpanel.db.Task.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A workspace task definition for Turborepo integration.\n \n Tasks with `exec` are compiled to Nix derivations and symlinked to\n `.tasks/bin/\u003ctask\u003e`. Turborepo invokes these via package.json scripts.\n \n Tasks without `exec` assume the script already exists in package.json.",
  "properties": {
    "cache": {
      "type": "boolean"
    },
    "cwd": {
      "type": "string"
    },
    "depends_on": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "description": {
      "type": "string"
    },
    "env": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "exec": {
      "type": "string"
    },
    "inputs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "interactive": {
      "type": "boolean"
    },
    "outputs": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "persistent": {
      "type": "boolean"
    }
  },
  "title": "Task",
  "type": "object"
}
