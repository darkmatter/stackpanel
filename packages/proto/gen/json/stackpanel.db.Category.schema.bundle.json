{
  "$defs": {
    "stackpanel.db.Category.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Onboarding category configuration",
      "properties": {
        "description": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "order": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "title": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Category",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Category.schema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Category.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
