{
  "$id": "stackpanel.db.HealthcheckResult.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "The result of executing a healthcheck",
  "properties": {
    "checkId": {
      "type": "string"
    },
    "durationMs": {
      "type": "integer"
    },
    "error": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "output": {
      "type": "string"
    },
    "status": {
      "enum": [
        "HEALTH_STATUS_UNSPECIFIED",
        "HEALTH_STATUS_HEALTHY",
        "HEALTH_STATUS_DEGRADED",
        "HEALTH_STATUS_UNHEALTHY",
        "HEALTH_STATUS_UNKNOWN",
        "HEALTH_STATUS_DISABLED"
      ],
      "title": "Health Status",
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    }
  },
  "required": [
    "checkId",
    "status",
    "durationMs",
    "timestamp"
  ],
  "title": "Healthcheck Result",
  "type": "object"
}
