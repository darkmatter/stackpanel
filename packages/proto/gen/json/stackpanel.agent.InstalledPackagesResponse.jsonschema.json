{
  "$id": "stackpanel.agent.InstalledPackagesResponse.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "count": {
      "anyOf": [
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ],
      "default": 0
    },
    "packages": {
      "items": {
        "$ref": "stackpanel.agent.InstalledPackage.jsonschema.json"
      },
      "type": "array"
    }
  },
  "title": "Installed Packages Response",
  "type": "object"
}
