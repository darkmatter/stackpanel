{
  "$defs": {
    "stackpanel.db.ModulePanel.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A UI panel provided by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModulePanelField.jsonschema.strict.json"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "order": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "enum": [
            "MODULE_PANEL_TYPE_UNSPECIFIED",
            "MODULE_PANEL_TYPE_STATUS",
            "MODULE_PANEL_TYPE_APPS_GRID",
            "MODULE_PANEL_TYPE_FORM",
            "MODULE_PANEL_TYPE_TABLE",
            "MODULE_PANEL_TYPE_CUSTOM"
          ],
          "title": "Module Panel Type",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "type",
        "order"
      ],
      "title": "Module Panel",
      "type": "object"
    },
    "stackpanel.db.ModulePanelField.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A field in a module panel",
      "properties": {
        "name": {
          "type": "string"
        },
        "options": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "MODULE_FIELD_TYPE_UNSPECIFIED",
            "MODULE_FIELD_TYPE_STRING",
            "MODULE_FIELD_TYPE_NUMBER",
            "MODULE_FIELD_TYPE_BOOLEAN",
            "MODULE_FIELD_TYPE_SELECT",
            "MODULE_FIELD_TYPE_MULTISELECT",
            "MODULE_FIELD_TYPE_APP_FILTER",
            "MODULE_FIELD_TYPE_COLUMNS",
            "MODULE_FIELD_TYPE_JSON"
          ],
          "title": "Module Field Type",
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "type",
        "value"
      ],
      "title": "Module Panel Field",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.ModulePanel.jsonschema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.ModulePanel.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
