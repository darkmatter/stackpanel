{
  "$defs": {
    "stackpanel.db.Sst.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "SST infrastructure configuration for AWS provisioning",
      "patternProperties": {
        "^(account_id)$": {
          "default": "",
          "type": "string"
        },
        "^(config_path)$": {
          "default": "",
          "type": "string"
        },
        "^(project_name)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "accountId": {
          "default": "",
          "type": "string"
        },
        "configPath": {
          "default": "",
          "type": "string"
        },
        "enable": {
          "default": false,
          "type": "boolean"
        },
        "iam": {
          "$ref": "#/$defs/stackpanel.db.SstIam.jsonschema.json"
        },
        "kms": {
          "$ref": "#/$defs/stackpanel.db.SstKms.jsonschema.json"
        },
        "oidc": {
          "$ref": "#/$defs/stackpanel.db.SstOidc.jsonschema.json"
        },
        "projectName": {
          "default": "",
          "type": "string"
        },
        "region": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Sst",
      "type": "object"
    },
    "stackpanel.db.SstFlyio.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Fly.io OIDC configuration",
      "patternProperties": {
        "^(app_name)$": {
          "default": "",
          "type": "string"
        },
        "^(org_id)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "appName": {
          "default": "",
          "type": "string"
        },
        "orgId": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Sst Flyio",
      "type": "object"
    },
    "stackpanel.db.SstGithubActions.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "GitHub Actions OIDC configuration",
      "properties": {
        "org": {
          "default": "",
          "type": "string"
        },
        "repo": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Sst Github Actions",
      "type": "object"
    },
    "stackpanel.db.SstIam.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "IAM role configuration",
      "patternProperties": {
        "^(role_name)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "roleName": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Sst Iam",
      "type": "object"
    },
    "stackpanel.db.SstKms.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "KMS key configuration for secrets encryption",
      "patternProperties": {
        "^(deletion_window_days)$": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "properties": {
        "alias": {
          "default": "",
          "type": "string"
        },
        "deletionWindowDays": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "enable": {
          "default": false,
          "type": "boolean"
        }
      },
      "title": "Sst Kms",
      "type": "object"
    },
    "stackpanel.db.SstOidc.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "OIDC provider configuration for IAM role assumption",
      "patternProperties": {
        "^(github_actions)$": {
          "$ref": "#/$defs/stackpanel.db.SstGithubActions.jsonschema.json"
        },
        "^(roles_anywhere)$": {
          "$ref": "#/$defs/stackpanel.db.SstRolesAnywhere.jsonschema.json"
        }
      },
      "properties": {
        "flyio": {
          "$ref": "#/$defs/stackpanel.db.SstFlyio.jsonschema.json"
        },
        "githubActions": {
          "$ref": "#/$defs/stackpanel.db.SstGithubActions.jsonschema.json"
        },
        "provider": {
          "default": "",
          "type": "string"
        },
        "rolesAnywhere": {
          "$ref": "#/$defs/stackpanel.db.SstRolesAnywhere.jsonschema.json"
        }
      },
      "title": "Sst Oidc",
      "type": "object"
    },
    "stackpanel.db.SstRolesAnywhere.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "AWS Roles Anywhere configuration",
      "patternProperties": {
        "^(trust_anchor_arn)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "trustAnchorArn": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Sst Roles Anywhere",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Sst.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Sst.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
