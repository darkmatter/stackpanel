{
  "$defs": {
    "stackpanel.db.Collaborator.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A GitHub collaborator",
      "properties": {
        "id": {
          "type": "integer"
        },
        "is_admin": {
          "type": "boolean"
        },
        "login": {
          "type": "string"
        },
        "public_keys": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "role": {
          "enum": [
            "COLLABORATOR_ROLE_UNSPECIFIED",
            "COLLABORATOR_ROLE_READ",
            "COLLABORATOR_ROLE_TRIAGE",
            "COLLABORATOR_ROLE_WRITE",
            "COLLABORATOR_ROLE_MAINTAIN",
            "COLLABORATOR_ROLE_ADMIN"
          ],
          "title": "Collaborator Role",
          "type": "string"
        }
      },
      "required": [
        "login",
        "id",
        "role",
        "is_admin"
      ],
      "title": "Collaborator",
      "type": "object"
    },
    "stackpanel.db.GithubCollaborators.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Auto-generated GitHub collaborators data",
      "properties": {
        "collaborators": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Collaborator.schema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "meta": {
          "$ref": "#/$defs/stackpanel.db.Meta.schema.strict.json"
        }
      },
      "title": "Github Collaborators",
      "type": "object"
    },
    "stackpanel.db.Meta.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Metadata about this generated file",
      "properties": {
        "generated_at": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      },
      "required": [
        "source",
        "generated_at"
      ],
      "title": "Meta",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.GithubCollaborators.schema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.GithubCollaborators.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
