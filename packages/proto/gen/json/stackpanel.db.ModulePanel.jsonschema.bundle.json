{
  "$defs": {
    "stackpanel.db.ModulePanel.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A UI panel provided by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModulePanelField.jsonschema.json"
          },
          "type": "array"
        },
        "id": {
          "default": "",
          "type": "string"
        },
        "order": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "title": {
          "default": "",
          "type": "string"
        },
        "type": {
          "anyOf": [
            {
              "pattern": "^MODULE_PANEL_TYPE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "MODULE_PANEL_TYPE_STATUS",
                "MODULE_PANEL_TYPE_APPS_GRID",
                "MODULE_PANEL_TYPE_FORM",
                "MODULE_PANEL_TYPE_TABLE",
                "MODULE_PANEL_TYPE_CUSTOM"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Module Panel Type"
        }
      },
      "title": "Module Panel",
      "type": "object"
    },
    "stackpanel.db.ModulePanelField.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A field in a module panel",
      "properties": {
        "name": {
          "default": "",
          "type": "string"
        },
        "options": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "anyOf": [
            {
              "pattern": "^MODULE_FIELD_TYPE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "MODULE_FIELD_TYPE_STRING",
                "MODULE_FIELD_TYPE_NUMBER",
                "MODULE_FIELD_TYPE_BOOLEAN",
                "MODULE_FIELD_TYPE_SELECT",
                "MODULE_FIELD_TYPE_MULTISELECT",
                "MODULE_FIELD_TYPE_APP_FILTER",
                "MODULE_FIELD_TYPE_COLUMNS",
                "MODULE_FIELD_TYPE_JSON"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Module Field Type"
        },
        "value": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Module Panel Field",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.ModulePanel.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.ModulePanel.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
