{
  "$defs": {
    "stackpanel.db.Category.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Onboarding category configuration",
      "properties": {
        "description": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "order": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "title": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Category",
      "type": "object"
    },
    "stackpanel.db.Onboarding.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Onboarding configuration for new team members",
      "patternProperties": {
        "^(auto_run)$": {
          "default": false,
          "type": "boolean"
        },
        "^(completion_message)$": {
          "default": "",
          "type": "string"
        },
        "^(persist_state)$": {
          "default": false,
          "type": "boolean"
        },
        "^(state_file)$": {
          "default": "",
          "type": "string"
        },
        "^(welcome_message)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "autoRun": {
          "default": false,
          "type": "boolean"
        },
        "categories": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Category.jsonschema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "completionMessage": {
          "default": "",
          "type": "string"
        },
        "enable": {
          "default": false,
          "type": "boolean"
        },
        "persistState": {
          "default": false,
          "type": "boolean"
        },
        "stateFile": {
          "default": "",
          "type": "string"
        },
        "steps": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Step.jsonschema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "welcomeMessage": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Onboarding",
      "type": "object"
    },
    "stackpanel.db.Step.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Onboarding step configuration",
      "patternProperties": {
        "^(check_command)$": {
          "type": "string"
        },
        "^(depends_on)$": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "^(skip_if)$": {
          "type": "string"
        }
      },
      "properties": {
        "category": {
          "default": "",
          "type": "string"
        },
        "checkCommand": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "dependsOn": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "description": {
          "type": "string"
        },
        "env": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "id": {
          "default": "",
          "type": "string"
        },
        "order": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "required": {
          "default": false,
          "type": "boolean"
        },
        "skipIf": {
          "type": "string"
        },
        "title": {
          "default": "",
          "type": "string"
        },
        "type": {
          "anyOf": [
            {
              "pattern": "^STEP_TYPE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "STEP_TYPE_COMMAND",
                "STEP_TYPE_MANUAL",
                "STEP_TYPE_CHECK",
                "STEP_TYPE_LINK",
                "STEP_TYPE_PROMPT"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Step Type"
        },
        "url": {
          "type": "string"
        }
      },
      "title": "Step",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Onboarding.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Onboarding.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
