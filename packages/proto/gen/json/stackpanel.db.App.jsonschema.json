{
  "$id": "stackpanel.db.App.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Configuration for a single application in the workspace",
  "properties": {
    "deploy": {
      "$ref": "stackpanel.db.AppDeploy.jsonschema.json"
    },
    "description": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "env": {
      "additionalProperties": {
        "$ref": "stackpanel.db.EnvironmentVariable.jsonschema.json"
      },
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "environmentIds": {
      "description": "Environment IDs for this app. Defaults to \"dev\", \"prod\", \"staging\", \"test\".",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "environments": {
      "additionalProperties": {
        "$ref": "stackpanel.db.AppEnvironment.jsonschema.json"
      },
      "description": "deprecated: use env instead\n Environment configurations (key = environment name like \"dev\", \"prod\").",
      "propertyNames": {
        "type": "string"
      },
      "type": "object"
    },
    "name": {
      "default": "",
      "type": "string"
    },
    "path": {
      "default": "",
      "type": "string"
    },
    "port": {
      "anyOf": [
        {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        {
          "pattern": "^-?[0-9]+$",
          "type": "string"
        }
      ]
    },
    "type": {
      "type": "string"
    }
  },
  "title": "App",
  "type": "object"
}
