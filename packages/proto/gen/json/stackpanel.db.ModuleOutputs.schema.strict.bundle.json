{
  "$defs": {
    "stackpanel.db.ModuleOutputFile.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A file generated by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "path",
        "type"
      ],
      "title": "Module Output File",
      "type": "object"
    },
    "stackpanel.db.ModuleOutputHealthcheck.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A healthcheck defined by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "severity",
        "type"
      ],
      "title": "Module Output Healthcheck",
      "type": "object"
    },
    "stackpanel.db.ModuleOutputPackage.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A package added by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "Module Output Package",
      "type": "object"
    },
    "stackpanel.db.ModuleOutputScript.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A script provided by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "Module Output Script",
      "type": "object"
    },
    "stackpanel.db.ModuleOutputs.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Aggregated outputs of what a module creates",
      "properties": {
        "files": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModuleOutputFile.schema.strict.json"
          },
          "type": "array"
        },
        "healthchecks": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModuleOutputHealthcheck.schema.strict.json"
          },
          "type": "array"
        },
        "module_id": {
          "type": "string"
        },
        "packages": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModuleOutputPackage.schema.strict.json"
          },
          "type": "array"
        },
        "scripts": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModuleOutputScript.schema.strict.json"
          },
          "type": "array"
        }
      },
      "required": [
        "module_id"
      ],
      "title": "Module Outputs",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.ModuleOutputs.schema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.ModuleOutputs.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
