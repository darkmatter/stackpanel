{
  "$defs": {
    "stackpanel.db.ModuleOutputFile.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A file generated by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "path": {
          "default": "",
          "type": "string"
        },
        "type": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Module Output File",
      "type": "object"
    },
    "stackpanel.db.ModuleOutputHealthcheck.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A healthcheck defined by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "id": {
          "default": "",
          "type": "string"
        },
        "name": {
          "default": "",
          "type": "string"
        },
        "severity": {
          "default": "",
          "type": "string"
        },
        "type": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Module Output Healthcheck",
      "type": "object"
    },
    "stackpanel.db.ModuleOutputPackage.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A package added by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "default": "",
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "title": "Module Output Package",
      "type": "object"
    },
    "stackpanel.db.ModuleOutputScript.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A script provided by a module",
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Module Output Script",
      "type": "object"
    },
    "stackpanel.db.ModuleOutputs.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Aggregated outputs of what a module creates",
      "patternProperties": {
        "^(module_id)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "files": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModuleOutputFile.jsonschema.json"
          },
          "type": "array"
        },
        "healthchecks": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModuleOutputHealthcheck.jsonschema.json"
          },
          "type": "array"
        },
        "moduleId": {
          "default": "",
          "type": "string"
        },
        "packages": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModuleOutputPackage.jsonschema.json"
          },
          "type": "array"
        },
        "scripts": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ModuleOutputScript.jsonschema.json"
          },
          "type": "array"
        }
      },
      "title": "Module Outputs",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.ModuleOutputs.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.ModuleOutputs.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
