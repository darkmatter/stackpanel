{
  "$defs": {
    "stackpanel.db.Postgres.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "PostgreSQL service configuration",
      "properties": {
        "databases": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "enable": {
          "default": false,
          "type": "boolean"
        },
        "extensions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "port": {
          "anyOf": [
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ]
        },
        "version": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Postgres",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Postgres.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Postgres.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
