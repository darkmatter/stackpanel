{
  "$defs": {
    "stackpanel.db.Caddy.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Caddy reverse proxy configuration",
      "properties": {
        "enable": {
          "type": "boolean"
        },
        "sites": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.CaddySite.schema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "required": [
        "enable"
      ],
      "title": "Caddy",
      "type": "object"
    },
    "stackpanel.db.CaddySite.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Caddy site configuration",
      "properties": {
        "tls": {
          "type": "boolean"
        },
        "upstream": {
          "type": "string"
        }
      },
      "required": [
        "upstream",
        "tls"
      ],
      "title": "Caddy Site",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Caddy.schema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Caddy.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
