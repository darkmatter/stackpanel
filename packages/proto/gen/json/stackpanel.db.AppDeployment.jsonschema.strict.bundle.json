{
  "$defs": {
    "stackpanel.db.AppDeployment.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Per-app deployment configuration",
      "properties": {
        "cloudflare": {
          "$ref": "#/$defs/stackpanel.db.CloudflareAppConfig.jsonschema.strict.json"
        },
        "enable": {
          "type": "boolean"
        },
        "fly": {
          "$ref": "#/$defs/stackpanel.db.FlyAppConfig.jsonschema.strict.json"
        },
        "provider": {
          "enum": [
            "DEPLOYMENT_PROVIDER_UNSPECIFIED",
            "DEPLOYMENT_PROVIDER_CLOUDFLARE",
            "DEPLOYMENT_PROVIDER_FLY",
            "DEPLOYMENT_PROVIDER_AWS_ECS",
            "DEPLOYMENT_PROVIDER_RAILWAY",
            "DEPLOYMENT_PROVIDER_RENDER"
          ],
          "title": "Deployment Provider",
          "type": "string"
        }
      },
      "required": [
        "enable",
        "provider"
      ],
      "title": "App Deployment",
      "type": "object"
    },
    "stackpanel.db.CloudflareAppConfig.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Cloudflare per-app deployment configuration",
      "properties": {
        "bindings": {
          "additionalProperties": {
            "type": "string"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "compatibility": {
          "type": "string"
        },
        "d1Databases": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kvNamespaces": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "r2Buckets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "route": {
          "type": "string"
        },
        "secrets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "CLOUDFLARE_WORKER_TYPE_UNSPECIFIED",
            "CLOUDFLARE_WORKER_TYPE_VITE",
            "CLOUDFLARE_WORKER_TYPE_WORKER",
            "CLOUDFLARE_WORKER_TYPE_PAGES"
          ],
          "title": "Cloudflare Worker Type",
          "type": "string"
        },
        "workerName": {
          "type": "string"
        }
      },
      "required": [
        "workerName",
        "type",
        "compatibility"
      ],
      "title": "Cloudflare App Config",
      "type": "object"
    },
    "stackpanel.db.FlyAppConfig.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Fly.io per-app deployment configuration",
      "properties": {
        "appName": {
          "type": "string"
        },
        "autoStart": {
          "type": "boolean"
        },
        "autoStop": {
          "enum": [
            "FLY_AUTO_STOP_UNSPECIFIED",
            "FLY_AUTO_STOP_OFF",
            "FLY_AUTO_STOP_STOP",
            "FLY_AUTO_STOP_SUSPEND"
          ],
          "title": "Fly Auto Stop",
          "type": "string"
        },
        "cpuKind": {
          "enum": [
            "FLY_MACHINE_CPU_KIND_UNSPECIFIED",
            "FLY_MACHINE_CPU_KIND_SHARED",
            "FLY_MACHINE_CPU_KIND_PERFORMANCE"
          ],
          "title": "Fly Machine Cpu Kind",
          "type": "string"
        },
        "cpus": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "forceHttps": {
          "type": "boolean"
        },
        "healthCheckInterval": {
          "type": "string"
        },
        "healthCheckPath": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        },
        "minMachines": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "region": {
          "type": "string"
        },
        "secrets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "appName",
        "region",
        "memory",
        "cpuKind",
        "cpus",
        "autoStop",
        "autoStart",
        "minMachines",
        "forceHttps"
      ],
      "title": "Fly App Config",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.AppDeployment.jsonschema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.AppDeployment.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
