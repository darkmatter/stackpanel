{
  "$defs": {
    "stackpanel.db.App.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Configuration for a single application in the workspace",
      "properties": {
        "deploy": {
          "$ref": "#/$defs/stackpanel.db.AppDeploy.jsonschema.strict.json"
        },
        "description": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "env": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.EnvironmentVariable.jsonschema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "environmentIds": {
          "description": "Environment IDs for this app. Defaults to \"dev\", \"prod\", \"staging\", \"test\".",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "environments": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.AppEnvironment.jsonschema.strict.json"
          },
          "description": "deprecated: use env instead\n Environment configurations (key = environment name like \"dev\", \"prod\").",
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "port": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "path"
      ],
      "title": "App",
      "type": "object"
    },
    "stackpanel.db.AppDeploy.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Deployment mapping for Colmena (targets, roles, and modules)",
      "properties": {
        "enable": {
          "type": "boolean"
        },
        "nixosModules": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "role": {
          "type": "string"
        },
        "secrets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "system": {
          "type": "string"
        },
        "targets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "enable"
      ],
      "title": "App Deploy",
      "type": "object"
    },
    "stackpanel.db.AppEnvironment.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Environment configuration (e.g., dev, staging, production)",
      "properties": {
        "description": {
          "type": "string"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Environment variables for this environment.\n Key: Environment variable name (e.g., DATABASE_URL)\n Value: Literal string or vals reference (e.g., ref+sops://...)",
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "extends": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "secrets": {
          "description": "Env var names in this environment that contain sensitive values.\n Used to auto-derive deployment.secrets — these are wrapped with\n alchemy.secret() at deploy time.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "name"
      ],
      "title": "App Environment",
      "type": "object"
    },
    "stackpanel.db.EnvironmentVariable.jsonschema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Environment variable for this app",
      "properties": {
        "defaultValue": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "secret": {
          "type": "boolean"
        },
        "sops": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "required",
        "secret"
      ],
      "title": "Environment Variable",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.App.jsonschema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.App.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
