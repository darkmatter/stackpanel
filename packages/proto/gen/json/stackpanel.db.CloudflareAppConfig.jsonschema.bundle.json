{
  "$defs": {
    "stackpanel.db.CloudflareAppConfig.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Cloudflare per-app deployment configuration",
      "patternProperties": {
        "^(d1_databases)$": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "^(kv_namespaces)$": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "^(r2_buckets)$": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "^(worker_name)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "bindings": {
          "additionalProperties": {
            "type": "string"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "compatibility": {
          "default": "",
          "type": "string"
        },
        "d1Databases": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "kvNamespaces": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "r2Buckets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "route": {
          "type": "string"
        },
        "secrets": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "anyOf": [
            {
              "pattern": "^CLOUDFLARE_WORKER_TYPE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "CLOUDFLARE_WORKER_TYPE_VITE",
                "CLOUDFLARE_WORKER_TYPE_WORKER",
                "CLOUDFLARE_WORKER_TYPE_PAGES"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Cloudflare Worker Type"
        },
        "workerName": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Cloudflare App Config",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.CloudflareAppConfig.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.CloudflareAppConfig.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
