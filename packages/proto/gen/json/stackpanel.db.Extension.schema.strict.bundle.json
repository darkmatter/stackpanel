{
  "$defs": {
    "stackpanel.db.Extension.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Extension configuration and metadata",
      "properties": {
        "apps": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.ExtensionAppData.schema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "builtin": {
          "type": "boolean"
        },
        "category": {
          "enum": [
            "EXTENSION_CATEGORY_UNSPECIFIED",
            "EXTENSION_CATEGORY_INFRASTRUCTURE",
            "EXTENSION_CATEGORY_CI_CD",
            "EXTENSION_CATEGORY_DATABASE",
            "EXTENSION_CATEGORY_SECRETS",
            "EXTENSION_CATEGORY_DEPLOYMENT",
            "EXTENSION_CATEGORY_DEVELOPMENT",
            "EXTENSION_CATEGORY_MONITORING",
            "EXTENSION_CATEGORY_INTEGRATION"
          ],
          "title": "Extension Category",
          "type": "string"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "features": {
          "$ref": "#/$defs/stackpanel.db.ExtensionFeatures.schema.strict.json"
        },
        "name": {
          "type": "string"
        },
        "panels": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.ExtensionPanel.schema.strict.json"
          },
          "type": "array"
        },
        "priority": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "source": {
          "$ref": "#/$defs/stackpanel.db.ExtensionSource.schema.strict.json"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "enabled",
        "builtin",
        "category",
        "priority"
      ],
      "title": "Extension",
      "type": "object"
    },
    "stackpanel.db.ExtensionAppData.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Extension data specific to an application",
      "properties": {
        "config": {
          "additionalProperties": {
            "type": "string"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "title": "Extension App Data",
      "type": "object"
    },
    "stackpanel.db.ExtensionFeatures.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Flags indicating which core stackpanel features this extension configures",
      "properties": {
        "checks": {
          "type": "boolean"
        },
        "files": {
          "type": "boolean"
        },
        "packages": {
          "type": "boolean"
        },
        "scripts": {
          "type": "boolean"
        },
        "secrets": {
          "type": "boolean"
        },
        "services": {
          "type": "boolean"
        },
        "shell_hooks": {
          "type": "boolean"
        },
        "tasks": {
          "type": "boolean"
        }
      },
      "required": [
        "files",
        "scripts",
        "tasks",
        "secrets",
        "shell_hooks",
        "packages",
        "services",
        "checks"
      ],
      "title": "Extension Features",
      "type": "object"
    },
    "stackpanel.db.ExtensionPanel.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "UI panel configuration for the web interface",
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.PanelField.schema.strict.json"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "order": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "enum": [
            "PANEL_TYPE_UNSPECIFIED",
            "PANEL_TYPE_STATUS",
            "PANEL_TYPE_APPS_GRID",
            "PANEL_TYPE_FORM",
            "PANEL_TYPE_TABLE",
            "PANEL_TYPE_CUSTOM"
          ],
          "title": "Panel Type",
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "type",
        "order"
      ],
      "title": "Extension Panel",
      "type": "object"
    },
    "stackpanel.db.ExtensionSource.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Extension source configuration",
      "properties": {
        "module_path": {
          "type": "string"
        },
        "package": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "type": {
          "enum": [
            "EXTENSION_SOURCE_TYPE_UNSPECIFIED",
            "EXTENSION_SOURCE_TYPE_BUILTIN",
            "EXTENSION_SOURCE_TYPE_LOCAL",
            "EXTENSION_SOURCE_TYPE_GITHUB",
            "EXTENSION_SOURCE_TYPE_NPM",
            "EXTENSION_SOURCE_TYPE_URL"
          ],
          "title": "Extension Source Type",
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "Extension Source",
      "type": "object"
    },
    "stackpanel.db.PanelField.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Configuration field for a panel",
      "properties": {
        "name": {
          "type": "string"
        },
        "options": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type": {
          "enum": [
            "FIELD_TYPE_UNSPECIFIED",
            "FIELD_TYPE_STRING",
            "FIELD_TYPE_NUMBER",
            "FIELD_TYPE_BOOLEAN",
            "FIELD_TYPE_SELECT",
            "FIELD_TYPE_MULTISELECT",
            "FIELD_TYPE_APP_FILTER",
            "FIELD_TYPE_COLUMNS",
            "FIELD_TYPE_JSON"
          ],
          "title": "Field Type",
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "type",
        "value"
      ],
      "title": "Panel Field",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.Extension.schema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.Extension.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
