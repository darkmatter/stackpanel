{
  "$defs": {
    "stackpanel.db.HealthSummary.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Overall health summary across all modules",
      "properties": {
        "last_updated": {
          "type": "string"
        },
        "modules": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.ModuleHealth.schema.strict.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "overall_status": {
          "enum": [
            "HEALTH_STATUS_UNSPECIFIED",
            "HEALTH_STATUS_HEALTHY",
            "HEALTH_STATUS_DEGRADED",
            "HEALTH_STATUS_UNHEALTHY",
            "HEALTH_STATUS_UNKNOWN",
            "HEALTH_STATUS_DISABLED"
          ],
          "title": "Health Status",
          "type": "string"
        },
        "total_checks": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "total_healthy": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      },
      "required": [
        "overall_status",
        "total_healthy",
        "total_checks",
        "last_updated"
      ],
      "title": "Health Summary",
      "type": "object"
    },
    "stackpanel.db.HealthcheckResult.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "The result of executing a healthcheck",
      "properties": {
        "check_id": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer"
        },
        "error": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "status": {
          "enum": [
            "HEALTH_STATUS_UNSPECIFIED",
            "HEALTH_STATUS_HEALTHY",
            "HEALTH_STATUS_DEGRADED",
            "HEALTH_STATUS_UNHEALTHY",
            "HEALTH_STATUS_UNKNOWN",
            "HEALTH_STATUS_DISABLED"
          ],
          "title": "Health Status",
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": [
        "check_id",
        "status",
        "duration_ms",
        "timestamp"
      ],
      "title": "Healthcheck Result",
      "type": "object"
    },
    "stackpanel.db.ModuleHealth.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Aggregated health status for a module",
      "properties": {
        "checks": {
          "items": {
            "$ref": "#/$defs/stackpanel.db.HealthcheckResult.schema.strict.json"
          },
          "type": "array"
        },
        "healthy_count": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        },
        "last_updated": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "status": {
          "enum": [
            "HEALTH_STATUS_UNSPECIFIED",
            "HEALTH_STATUS_HEALTHY",
            "HEALTH_STATUS_DEGRADED",
            "HEALTH_STATUS_UNHEALTHY",
            "HEALTH_STATUS_UNKNOWN",
            "HEALTH_STATUS_DISABLED"
          ],
          "title": "Health Status",
          "type": "string"
        },
        "total_count": {
          "maximum": 2147483647,
          "minimum": -2147483648,
          "type": "integer"
        }
      },
      "required": [
        "module",
        "status",
        "healthy_count",
        "total_count",
        "last_updated"
      ],
      "title": "Module Health",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.HealthSummary.schema.strict.bundle.json",
  "$ref": "#/$defs/stackpanel.db.HealthSummary.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
