{
  "$defs": {
    "stackpanel.db.Collaborator.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "A GitHub collaborator",
      "patternProperties": {
        "^(is_admin)$": {
          "default": false,
          "type": "boolean"
        },
        "^(public_keys)$": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "properties": {
        "id": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "pattern": "^-?[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "isAdmin": {
          "default": false,
          "type": "boolean"
        },
        "login": {
          "default": "",
          "type": "string"
        },
        "publicKeys": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "role": {
          "anyOf": [
            {
              "pattern": "^COLLABORATOR_ROLE_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "COLLABORATOR_ROLE_READ",
                "COLLABORATOR_ROLE_TRIAGE",
                "COLLABORATOR_ROLE_WRITE",
                "COLLABORATOR_ROLE_MAINTAIN",
                "COLLABORATOR_ROLE_ADMIN"
              ],
              "type": "string"
            },
            {
              "maximum": 2147483647,
              "minimum": -2147483648,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Collaborator Role"
        }
      },
      "title": "Collaborator",
      "type": "object"
    },
    "stackpanel.db.GithubCollaborators.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Auto-generated GitHub collaborators data",
      "properties": {
        "collaborators": {
          "additionalProperties": {
            "$ref": "#/$defs/stackpanel.db.Collaborator.jsonschema.json"
          },
          "propertyNames": {
            "type": "string"
          },
          "type": "object"
        },
        "meta": {
          "$ref": "#/$defs/stackpanel.db.Meta.jsonschema.json"
        }
      },
      "title": "Github Collaborators",
      "type": "object"
    },
    "stackpanel.db.Meta.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "description": "Metadata about this generated file",
      "patternProperties": {
        "^(generated_at)$": {
          "default": "",
          "type": "string"
        }
      },
      "properties": {
        "generatedAt": {
          "default": "",
          "type": "string"
        },
        "source": {
          "default": "",
          "type": "string"
        }
      },
      "title": "Meta",
      "type": "object"
    }
  },
  "$id": "stackpanel.db.GithubCollaborators.jsonschema.bundle.json",
  "$ref": "#/$defs/stackpanel.db.GithubCollaborators.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
