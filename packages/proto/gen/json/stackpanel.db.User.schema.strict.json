{
  "$id": "stackpanel.db.User.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "A team member with access to the project",
  "properties": {
    "email": {
      "type": "string"
    },
    "github": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "public_keys": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "secrets_allowed_environments": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "name"
  ],
  "title": "User",
  "type": "object"
}
