{
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.953.0",
    "@aws-sdk/client-ecr": "^3.953.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.953.0",
    "@aws-sdk/client-iam": "^3.953.0",
    "@aws-sdk/client-kms": "^3.953.0",
    "@aws-sdk/client-ssm": "^3.953.0",
    "@aws-sdk/client-sts": "^3.953.0",
    "@distilled.cloud/cloudflare": "^0.10.0",
    "@distilled.cloud/neon": "^0.10.0",
    "@docker/node-sdk": "^0.0.17",
    "@effect/platform": "^0.96.0",
    "@gen/config": "workspace:*",
    "@gen/env": "workspace:*",
    "@pulumi/aws": "^7.15.0",
    "@stackpanel/config": "workspace:*",
    "alchemy": "^0.81.2",
    "alchemy-effect": "catalog:",
    "better-auth": "^1.6.1",
    "effect": "catalog:",
    "sst": "^3.17.25"
  },
  "devDependencies": {
    "bun2nix": "latest"
  },
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "name": "@stackpanel/infra",
  "private": true,
  "scripts": {
    "alchemy:deploy": "alchemy deploy",
    "alchemy:destroy": "alchemy destroy",
    "alchemy:dev": "alchemy dev",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
    "dev": "alchemy dev",
    "postinstall": "test -f bun.lock && bun2nix -o bun.nix || true",
    "sst:deploy": "bunx sst deploy",
    "sst:dev": "bunx sst dev",
    "sst:remove": "bunx sst remove",
    "test": "echo 'Add test script here'"
  },
  "type": "module",
  "version": "0.0.0"
}
