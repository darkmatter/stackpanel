{
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.953.0",
    "@aws-sdk/client-ecr": "^3.953.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.953.0",
    "@aws-sdk/client-iam": "^3.953.0",
    "@aws-sdk/client-kms": "^3.953.0",
    "@aws-sdk/client-ssm": "^3.953.0",
    "@aws-sdk/client-sts": "^3.953.0",
    "@pulumi/aws": "^7.15.0",
    "alchemy": "^0.81.2",
    "sst": "^3.17.25"
  },
  "devDependencies": {
    "bun2nix": "latest"
  },
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "name": "@stackpanel/infra",
  "private": true,
  "scripts": {
    "alchemy:deploy": "alchemy deploy",
    "alchemy:destroy": "alchemy destroy",
    "alchemy:dev": "alchemy dev",
    "container:build:web": "cd ../.. && nix build --impure .#packages.x86_64-linux.container-web",
    "container:push:web": "cd ../.. && nix run --impure .#copy-container-web -- docker://registry.fly.io/ --dest-creds x:$(flyctl auth token)",
    "deploy:web": "cd ../.. && (flyctl status -a stackpanel-web > /dev/null 2>&1 || flyctl apps create stackpanel-web --org darkmatter) && flyctl deploy --config apps/web/fly.toml --image registry.fly.io/stackpanel-web:latest",
    "postinstall": "test -f bun.lock && bun2nix -o bun.nix || true",
    "ship:web": "turbo run deploy:web",
    "sst:deploy": "bunx sst deploy",
    "sst:dev": "bunx sst dev",
    "sst:remove": "bunx sst remove"
  },
  "type": "module"
}
