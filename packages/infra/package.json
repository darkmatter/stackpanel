{
  "dependencies": {
    "@aws-sdk/client-iam": "catalog:",
    "@aws-sdk/client-kms": "catalog:",
    "@aws-sdk/client-ssm": "catalog:",
    "@aws-sdk/client-sts": "catalog:",
    "@pulumi/aws": "catalog:",
    "alchemy": "catalog:",
    "sst": "catalog:"
  },
  "devDependencies": {
    "bun2nix": "latest"
  },
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "name": "@stackpanel/infra",
  "private": true,
  "scripts": {
    "alchemy:deploy": "alchemy deploy",
    "alchemy:destroy": "alchemy destroy",
    "alchemy:dev": "alchemy dev",
    "postinstall": "test -f bun.lock && bun2nix -o bun.nix || true",
    "sst:deploy": "bunx sst deploy",
    "sst:dev": "bunx sst dev",
    "sst:remove": "bunx sst remove"
  },
  "type": "module"
}
