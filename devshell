#!/usr/bin/env bash
# devshell - Enter a clean development environment
# 
# This script enters the Nix devshell with a clean environment,
# ignoring host shell aliases and most environment variables.
#
# Generated by stackpanel. Regenerate with: nix develop --impure -c devshell-regen
#
# Usage:
#   ./devshell              # Enter clean devshell (interactive)
#   ./devshell --dirty      # Enter normal devshell (inherit host env)
#   ./devshell -- <cmd>     # Run a one-off command in the devshell
#
set -euo pipefail

cd "$(dirname "$0")"

if [[ "${1:-}" == "--direnv" ]]; then
  shift
  nix develop \
    --ignore-environment \
    --impure \
    --keep HOME \
  --keep USER \
  --keep LOGNAME \
  --keep SHELL \
  --keep TMPDIR \
  --keep TERM \
  --keep COLORTERM \
  --keep TERM_PROGRAM \
  --keep TERM_PROGRAM_VERSION \
  --keep LANG \
  --keep LC_ALL \
  --keep LC_CTYPE \
  --keep SSH_AUTH_SOCK \
  --keep SSH_SOCKET_DIR \
  --keep GPG_AGENT_INFO \
  --keep GNUPGHOME \
  --keep EDITOR \
  --keep VISUAL \
  --keep PAGER \
  --keep __CF_USER_TEXT_ENCODING \
  --keep COMMAND_MODE \
    --command env -0 "$@" \
  | while IFS= read -r -d '' kv; do
      key="${kv%%=*}"
      val="${kv#*=}"
      printf 'export %s=%q\n' "$key" "$val"
    done
  exit
fi

if [[ "${1:-}" == "--dirty" ]]; then
  shift
  echo "🔧 Entering devshell (inheriting host environment)..."
  exec nix develop --impure "$@"
fi

# Check for -- separator (run one-off command)
if [[ "${1:-}" == "--" ]]; then
  shift
  if [[ $# -eq 0 ]]; then
    echo "Error: No command specified after --" >&2
    echo "Usage: ./devshell -- <command> [args...]" >&2
    exit 1
  fi
  exec nix develop \
    --ignore-environment \
    --impure \
    --keep HOME \
  --keep USER \
  --keep LOGNAME \
  --keep SHELL \
  --keep TMPDIR \
  --keep TERM \
  --keep COLORTERM \
  --keep TERM_PROGRAM \
  --keep TERM_PROGRAM_VERSION \
  --keep LANG \
  --keep LC_ALL \
  --keep LC_CTYPE \
  --keep SSH_AUTH_SOCK \
  --keep SSH_SOCKET_DIR \
  --keep GPG_AGENT_INFO \
  --keep GNUPGHOME \
  --keep EDITOR \
  --keep VISUAL \
  --keep PAGER \
  --keep __CF_USER_TEXT_ENCODING \
  --keep COMMAND_MODE \
    --command "$@"
fi

echo "🧹 Entering clean devshell..."
exec nix develop \
  --ignore-environment \
  --impure \
  --keep HOME \
  --keep USER \
  --keep LOGNAME \
  --keep SHELL \
  --keep TMPDIR \
  --keep TERM \
  --keep COLORTERM \
  --keep TERM_PROGRAM \
  --keep TERM_PROGRAM_VERSION \
  --keep LANG \
  --keep LC_ALL \
  --keep LC_CTYPE \
  --keep SSH_AUTH_SOCK \
  --keep SSH_SOCKET_DIR \
  --keep GPG_AGENT_INFO \
  --keep GNUPGHOME \
  --keep EDITOR \
  --keep VISUAL \
  --keep PAGER \
  --keep __CF_USER_TEXT_ENCODING \
  --keep COMMAND_MODE \
  "$@"
