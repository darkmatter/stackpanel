# ==============================================================================
# config.nix.example
#
# Stackpanel project configuration example with inline documentation.
#
# This file is auto-generated from option descriptions. Copy sections you need
# to your config.nix and customize as needed.
#
# To regenerate: run 'generate-config-example' in your devshell
# For minimal version: run 'generate-config-example --no-comments'
# ==============================================================================
{
  # ----------------------------------------------------------------------------
  # _moduleMetas
  # ----------------------------------------------------------------------------
  # Fast module metadata for discovery without full module evaluation. Each key
  # is a module ID, value is the contents of that module's meta.nix. This is set
  # automatically by the module auto-discovery in modules/default.nix.
  _moduleMetas = { };

  # ----------------------------------------------------------------------------
  # AppModules
  # ----------------------------------------------------------------------------
  # Additional modules to extend app configuration options. This allows other
  # modules to add functionality to each app, such as scaffolding, IDE support,
  # deployment settings, etc. These modules are applied to each app under
  # `stackpanel.apps.<appName>.<module>`.
  appModules = [ ];

  # ----------------------------------------------------------------------------
  # Apps
  # ----------------------------------------------------------------------------
  apps = {
    # Colmena deployment mapping for this app
    <name> = {
      deploy = { };
    };

    # Enable deployment mapping for this app
    <name> = {
      deploy = {
        enable = false;
      };
    };

    # Extra NixOS modules to import for this app
    <name> = {
      deploy = {
        nixos-modules = [ ];
      };
    };

    # Deployment role label for this app
    <name> = {
      deploy = {
        role = null;
      };
    };

    # Secret references required by this app during deploy
    <name> = {
      deploy = {
        secrets = [ ];
      };
    };

    # Target system/architecture (e.g., x86_64-linux)
    <name> = {
      deploy = {
        system = null;
      };
    };

    # Target machine ids or tag selectors
    <name> = {
      deploy = {
        targets = [ ];
      };
    };

    # Environment variable names to bind to the deployed app. Each name is read
    # from `process.env` at deploy time. Mark sensitive ones in `secrets`.
    <name> = {
      deployment = {
        bindings = [
  "DATABASE_URL"
  "CORS_ORIGIN"
  "BETTER_AUTH_SECRET"
];
      };
    };

    # Whether to enable deployment for this app.
    <name> = {
      deployment = {
        enable = true;
      };
    };

    # Deployment host/platform. Combined with `framework` to determine the
    # alchemy resource type: framework × host → alchemy resource
    # tanstack-start × cloudflare → TanStackStart nextjs × cloudflare →
    # Nextjs vite × cloudflare → cloudflare.Vite hono × cloudflare →
    # cloudflare.Worker * × fly → Fly container
    <name> = {
      deployment = {
        host = "cloudflare";
      };
    };

    # Subset of `bindings` that contain sensitive values. These are wrapped with
    # `alchemy.secret()` at deploy time.
    <name> = {
      deployment = {
        secrets = [
  "DATABASE_URL"
  "BETTER_AUTH_SECRET"
];
      };
    };

    # Description of the app
    <name> = {
      description = null;
    };

    # Local development domain
    <name> = {
      domain = null;
    };

    # Environment configurations (key = environment name like "dev", "prod").
    <name> = {
      environments = { };
    };

    # (optional) Description of the environment
    <name> = {
      environments = {
        <name> = {
          description = null;
        };
      };
    };

    # Environment variables for this environment. Key: Environment variable name
    # (e.g., DATABASE_URL) Value: Literal string or vals reference (e.g.,
    # ref+sops://...)
    <name> = {
      environments = {
        <name> = {
          env = { };
        };
      };
    };

    # Name of the environment
    <name> = {
      environments = {
        <name> = {
          name = "";
        };
      };
    };

    # Whether to enable Astro (static/SSR).
    <name> = {
      framework = {
        astro = {
          enable = true;
        };
      };
    };

    # Whether to enable Hono API server.
    <name> = {
      framework = {
        hono = {
          enable = true;
        };
      };
    };

    # Entrypoint file for the Hono worker.
    <name> = {
      framework = {
        hono = {
          entrypoint = "src/index.ts";
        };
      };
    };

    # Whether to enable Next.js (App Router or Pages).
    <name> = {
      framework = {
        nextjs = {
          enable = true;
        };
      };
    };

    # Next.js output mode.
    <name> = {
      framework = {
        nextjs = {
          output = "standalone";
        };
      };
    };

    # Whether to enable Nuxt.
    <name> = {
      framework = {
        nuxt = {
          enable = true;
        };
      };
    };

    # Whether to enable Remix.
    <name> = {
      framework = {
        remix = {
          enable = true;
        };
      };
    };

    # Whether to enable TanStack Start (full-stack SSR with TanStack Router +
    # Nitro).
    <name> = {
      framework = {
        tanstack-start = {
          enable = true;
        };
      };
    };

    # Output directory for built assets.
    <name> = {
      framework = {
        vite = {
          assets-dir = "dist";
        };
      };
    };

    # Whether to enable Vite SPA (React, Vue, Svelte, etc.).
    <name> = {
      framework = {
        vite = {
          enable = true;
        };
      };
    };

    # Enable Vite SSR mode.
    <name> = {
      framework = {
        vite = {
          ssr = false;
        };
      };
    };

    # Display name of the app
    <name> = {
      name = "";
    };

    # Port offset from base port. If null, offset is determined by position in
    # apps attrset.
    <name> = {
      offset = 5;
    };

    # NPM package name for turbo filter (e.g., "@stackpanel/web"). If null,
    # defaults to the app name.
    <name> = {
      packageName = "@myorg/web";
    };

    # Relative path to the app directory
    <name> = {
      path = "";
    };

    # Development server port
    <name> = {
      port = null;
    };

    # Enable TLS for the vhost (requires Step CA)
    <name> = {
      tls = false;
    };

    # Build tool definition (wrapped).
    <name> = {
      tooling = {
        build = null;
      };
    };

    # Additional build steps (wrapped).
    <name> = {
      tooling = {
        build-steps = [ ];
      };
    };

    # Arguments passed to the tool.
    <name> = {
      tooling = {
        build-steps = {
          * = {
            args = [ ];
          };
        };
      };
    };

    # Optional binary name if the package provides multiple executables.
    <name> = {
      tooling = {
        build-steps = {
          * = {
            bin = null;
          };
        };
      };
    };

    # Argument prefix inserted before configPath (e.g. ["--config"]).
    <name> = {
      tooling = {
        build-steps = {
          * = {
            configArg = null;
          };
        };
      };
    };

    # Repo-relative config file path for the tool.
    <name> = {
      tooling = {
        build-steps = {
          * = {
            configPath = null;
          };
        };
      };
    };

    # Override working directory (repo-relative). Defaults to app path.
    <name> = {
      tooling = {
        build-steps = {
          * = {
            cwd = null;
          };
        };
      };
    };

    # Environment variables for the tool.
    <name> = {
      tooling = {
        build-steps = {
          * = {
            env = { };
          };
        };
      };
    };

    # Package that provides the tool binary.
    <name> = {
      tooling = {
        build-steps = {
          * = {
            package = pkgs.package-name;
          };
        };
      };
    };

    # Arguments passed to the tool.
    <name> = {
      tooling = {
        build = {
          args = [ ];
        };
      };
    };

    # Optional binary name if the package provides multiple executables.
    <name> = {
      tooling = {
        build = {
          bin = null;
        };
      };
    };

    # Argument prefix inserted before configPath (e.g. ["--config"]).
    <name> = {
      tooling = {
        build = {
          configArg = null;
        };
      };
    };

    # Repo-relative config file path for the tool.
    <name> = {
      tooling = {
        build = {
          configPath = null;
        };
      };
    };

    # Override working directory (repo-relative). Defaults to app path.
    <name> = {
      tooling = {
        build = {
          cwd = null;
        };
      };
    };

    # Environment variables for the tool.
    <name> = {
      tooling = {
        build = {
          env = { };
        };
      };
    };

    # Package that provides the tool binary.
    <name> = {
      tooling = {
        build = {
          package = pkgs.package-name;
        };
      };
    };

    # Dev tool definition (wrapped).
    <name> = {
      tooling = {
        dev = null;
      };
    };

    # Arguments passed to the tool.
    <name> = {
      tooling = {
        dev = {
          args = [ ];
        };
      };
    };

    # Optional binary name if the package provides multiple executables.
    <name> = {
      tooling = {
        dev = {
          bin = null;
        };
      };
    };

    # Argument prefix inserted before configPath (e.g. ["--config"]).
    <name> = {
      tooling = {
        dev = {
          configArg = null;
        };
      };
    };

    # Repo-relative config file path for the tool.
    <name> = {
      tooling = {
        dev = {
          configPath = null;
        };
      };
    };

    # Override working directory (repo-relative). Defaults to app path.
    <name> = {
      tooling = {
        dev = {
          cwd = null;
        };
      };
    };

    # Environment variables for the tool.
    <name> = {
      tooling = {
        dev = {
          env = { };
        };
      };
    };

    # Package that provides the tool binary.
    <name> = {
      tooling = {
        dev = {
          package = pkgs.package-name;
        };
      };
    };

    # Formatter definitions (wrapped).
    <name> = {
      tooling = {
        formatters = [ ];
      };
    };

    # Arguments passed to the tool.
    <name> = {
      tooling = {
        formatters = {
          * = {
            args = [ ];
          };
        };
      };
    };

    # Optional binary name if the package provides multiple executables.
    <name> = {
      tooling = {
        formatters = {
          * = {
            bin = null;
          };
        };
      };
    };

    # Argument prefix inserted before configPath (e.g. ["--config"]).
    <name> = {
      tooling = {
        formatters = {
          * = {
            configArg = null;
          };
        };
      };
    };

    # Repo-relative config file path for the tool.
    <name> = {
      tooling = {
        formatters = {
          * = {
            configPath = null;
          };
        };
      };
    };

    # Override working directory (repo-relative). Defaults to app path.
    <name> = {
      tooling = {
        formatters = {
          * = {
            cwd = null;
          };
        };
      };
    };

    # Environment variables for the tool.
    <name> = {
      tooling = {
        formatters = {
          * = {
            env = { };
          };
        };
      };
    };

    # Package that provides the tool binary.
    <name> = {
      tooling = {
        formatters = {
          * = {
            package = pkgs.package-name;
          };
        };
      };
    };

    # Install tool definition (wrapped).
    <name> = {
      tooling = {
        install = null;
      };
    };

    # Arguments passed to the tool.
    <name> = {
      tooling = {
        install = {
          args = [ ];
        };
      };
    };

    # Optional binary name if the package provides multiple executables.
    <name> = {
      tooling = {
        install = {
          bin = null;
        };
      };
    };

    # Argument prefix inserted before configPath (e.g. ["--config"]).
    <name> = {
      tooling = {
        install = {
          configArg = null;
        };
      };
    };

    # Repo-relative config file path for the tool.
    <name> = {
      tooling = {
        install = {
          configPath = null;
        };
      };
    };

    # Override working directory (repo-relative). Defaults to app path.
    <name> = {
      tooling = {
        install = {
          cwd = null;
        };
      };
    };

    # Environment variables for the tool.
    <name> = {
      tooling = {
        install = {
          env = { };
        };
      };
    };

    # Package that provides the tool binary.
    <name> = {
      tooling = {
        install = {
          package = pkgs.package-name;
        };
      };
    };

    # Linter definitions (wrapped).
    <name> = {
      tooling = {
        linters = [ ];
      };
    };

    # Arguments passed to the tool.
    <name> = {
      tooling = {
        linters = {
          * = {
            args = [ ];
          };
        };
      };
    };

    # Optional binary name if the package provides multiple executables.
    <name> = {
      tooling = {
        linters = {
          * = {
            bin = null;
          };
        };
      };
    };

    # Argument prefix inserted before configPath (e.g. ["--config"]).
    <name> = {
      tooling = {
        linters = {
          * = {
            configArg = null;
          };
        };
      };
    };

    # Repo-relative config file path for the tool.
    <name> = {
      tooling = {
        linters = {
